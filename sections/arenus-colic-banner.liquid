{%- liquid
  assign has_image = false

  if section.settings.image != blank
    assign has_image = true
  endif

  assign fetch_priority = 'auto'
  if section.index == 1
    assign fetch_priority = 'high'
  endif
-%}

<div
  id="ArenusColBanner-{{ section.id }}"
  class="arenus-colb"
  style="
    --colb-bg: {{ section.settings.background_color }};
    --colb-text: {{ section.settings.text_color }};
    --colb-media-opacity: {{ section.settings.media_opacity | divided_by: 100.0 }};
    --colb-heading-size: {{ section.settings.heading_size_mobile }}px;
    --colb-heading-size-desktop: {{ section.settings.heading_size_desktop }}px;
    --colb-min-height: {{ section.settings.min_height_mobile }}px;
    --colb-min-height-desktop: {{ section.settings.min_height_desktop }}px;
    --colb-content-max-width: {{ section.settings.content_max_width_desktop }}px;
  "
>
  {%- comment -%} Background image {%- endcomment -%}
  <div class="arenus-colb__media">
    {%- if has_image -%}
      {{
        section.settings.image
        | image_url: width: 3840
        | image_tag:
          width: section.settings.image.width,
          widths: '416, 600, 800, 1200, 1600, 1920, 2560, 3840',
          height: section.settings.image.height,
          alt: section.settings.image.alt,
          class: 'arenus-colb__image',
          sizes: '100vw',
          fetchpriority: fetch_priority
      }}
    {%- endif -%}
  </div>

  {%- comment -%} Overlay {%- endcomment -%}
  {%- if section.settings.show_overlay -%}
    {% render 'overlay', settings: section.settings %}
  {%- endif -%}

  {%- comment -%} Content {%- endcomment -%}
  <div class="arenus-colb__content">
    <div class="arenus-colb__text-group">
      <div class="arenus-colb__inner-text">
        {%- if section.settings.heading != blank -%}
          <h1 class="arenus-colb__heading">{{ section.settings.heading }}</h1>
        {%- endif -%}

        {%- if section.settings.description != blank -%}
          <div class="arenus-colb__body">{{ section.settings.description }}</div>
        {%- endif -%}
      </div>

      {%- if section.settings.button_label != blank -%}
        <a
          href="{{ section.settings.button_link }}"
          class="arenus-colb__btn"
        >
          {{ section.settings.button_label }}
        </a>
      {%- endif -%}
    </div>
  </div>
</div>

{% stylesheet %}
  /* ===== Arenus Colic Banner — Mobile-first ===== */

  .arenus-colb {
    position: relative;
    overflow: hidden;
    background-color: var(--colb-bg, #191919);
    color: var(--colb-text, #fff);
  }

  /* Background image */
  .arenus-colb__media {
    position: absolute;
    inset: 0;
    opacity: var(--colb-media-opacity, 0.3);
    z-index: 0;
  }

  .arenus-colb__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center center;
  }

  /* Content */
  .arenus-colb__content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    align-items: center;
    padding: 20px;
    min-height: var(--colb-min-height, 540px);
    text-align: center;
  }

  /* ── Text group (heading + description) ── */
  .arenus-colb__text-group {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
  }

  .arenus-colb__inner-text {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    width: 100%;
  }

  .arenus-colb__heading {
    font-family: var(--font-heading--family);
    font-style: var(--font-heading--style);
    font-weight: var(--font-heading--weight);
    font-size: var(--colb-heading-size, 32px);
    line-height: 1.1;
    letter-spacing: -0.64px;
    margin: 0;
  }

  .arenus-colb__body {
    font-family: var(--font-body--family);
    font-weight: var(--font-body--weight);
    font-size: 14px;
    line-height: 1.5;
    letter-spacing: -0.14px;
  }

  .arenus-colb__body p {
    margin: 0;
  }

  /* ── CTA button (outlined) ── */
  .arenus-colb__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 202px;
    padding: 12px 24px;
    font-family: var(--font-body--family);
    font-weight: 500;
    font-size: 14px;
    line-height: 1;
    letter-spacing: 0;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--colb-text, #fff);
    background: transparent;
    border: 1px solid var(--colb-text, #fff);
    border-radius: 6px;
    cursor: pointer;
    transition: background-color 0.2s, color 0.2s;
    white-space: nowrap;
    box-sizing: border-box;
  }

  .arenus-colb__btn:hover {
    background-color: var(--colb-text, #fff);
    color: var(--colb-bg, #191919);
  }

  /* ===== Desktop ===== */
  @media screen and (min-width: 750px) {
    .arenus-colb__content {
      justify-content: flex-end;
      padding: 102px 160px 60px;
      min-height: var(--colb-min-height-desktop, 640px);
    }

    .arenus-colb__inner-text {
      max-width: var(--colb-content-max-width, 860px);
    }

    .arenus-colb__heading {
      font-size: var(--colb-heading-size-desktop, 56px);
      line-height: 1;
      letter-spacing: -0.8px;
    }

    .arenus-colb__body {
      font-size: 18px;
      line-height: 1.4;
      letter-spacing: -0.36px;
    }

    .arenus-colb__btn {
      width: 200px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Colic Banner",
  "tag": "section",
  "class": "arenus-colb-wrapper section-wrapper",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Colic Assurance Program"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "ENROLL NOW"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "range",
      "id": "media_opacity",
      "label": "Image opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 30
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "label": "Heading size (mobile)",
      "min": 20,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "heading_size_desktop",
      "label": "Heading size (desktop)",
      "min": 20,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 56
    },
    {
      "type": "range",
      "id": "min_height_mobile",
      "label": "Min height (mobile)",
      "min": 200,
      "max": 700,
      "step": 10,
      "unit": "px",
      "default": 540
    },
    {
      "type": "range",
      "id": "min_height_desktop",
      "label": "Min height (desktop)",
      "min": 200,
      "max": 900,
      "step": 10,
      "unit": "px",
      "default": 640
    },
    {
      "type": "range",
      "id": "content_max_width_desktop",
      "label": "Content max width (desktop)",
      "min": 600,
      "max": 1200,
      "step": 10,
      "unit": "px",
      "default": 860
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#191919"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Overlay"
    },
    {
      "type": "checkbox",
      "id": "show_overlay",
      "label": "Show overlay",
      "default": true
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay color",
      "alpha": true,
      "default": "#00000033",
      "visible_if": "{{ section.settings.show_overlay }}"
    },
    {
      "type": "select",
      "id": "overlay_style",
      "label": "Overlay style",
      "options": [
        {
          "value": "solid",
          "label": "Solid"
        },
        {
          "value": "gradient",
          "label": "Gradient"
        }
      ],
      "default": "gradient",
      "visible_if": "{{ section.settings.show_overlay }}"
    },
    {
      "type": "select",
      "id": "gradient_direction",
      "label": "Gradient direction",
      "options": [
        {
          "value": "to top",
          "label": "Up"
        },
        {
          "value": "to bottom",
          "label": "Down"
        }
      ],
      "default": "to top",
      "visible_if": "{{ section.settings.show_overlay and section.settings.overlay_style == 'gradient' }}"
    }
  ],
  "presets": [
    {
      "name": "Colic Banner",
      "category": "Banners",
      "settings": {
        "heading": "Colic Assurance Program",
        "button_label": "ENROLL NOW",
        "media_opacity": 30,
        "heading_size_mobile": 32,
        "heading_size_desktop": 56,
        "min_height_mobile": 540,
        "min_height_desktop": 640,
        "content_max_width_desktop": 860,
        "background_color": "#191919",
        "text_color": "#ffffff",
        "show_overlay": true,
        "overlay_color": "#00000033",
        "overlay_style": "gradient",
        "gradient_direction": "to top"
      }
    }
  ]
}
{% endschema %}
