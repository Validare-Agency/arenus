    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "About Us Content",
      "category": "Text",
      "settings": {
        "sub_heading": "Ride for a Green World",
        "hashtag_text": "#SHAREYOURLEGACY",
        "background_color": "#ffffff",
        "text_color": "#000000",
        "link_color": "#000000",
        "padding_top": 40,
        "padding_bottom": 40
      }
    }
  ]
}
{% endschema %}
