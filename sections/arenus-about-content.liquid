      "type": "richtext",
      "id": "sub_content",
      "label": "Sub-section text"
    },
    {
      "type": "header",
      "content": "Videos"
    },
    {
      "type": "url",
      "id": "video_url_1",
      "label": "YouTube video URL 1"
    },
    {
      "type": "url",
      "id": "video_url_2",
      "label": "YouTube video URL 2"
    },
    {
      "type": "header",
      "content": "Hashtag"
    },
    {
      "type": "text",
      "id": "hashtag_text",
      "label": "Hashtag text",
      "default": "#SHAREYOURLEGACY"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "link_color",
      "label": "Link color",
      "default": "#000000"
    },
    {
