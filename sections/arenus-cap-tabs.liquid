{%- comment -%}
  Arenus — CAP (Colic Assurance Program) Tabs
  Square tile grid with icon + label. Each tile links to a CAP sub-page.
{%- endcomment -%}

<section
  id="ArenusCapTabs-{{ section.id }}"
  class="arenus-cap-tabs c-page-width"
  style="
    padding-block-start: {{ section.settings.padding_top }}px;
    padding-block-end: {{ section.settings.padding_bottom }}px;
  "
>
  {%- if section.settings.heading != blank -%}
    <h2 class="arenus-cap-tabs__heading">{{ section.settings.heading }}</h2>
  {%- endif -%}

  {%- if section.blocks.size > 0 -%}
    <ul class="arenus-cap-tabs__grid" role="list">
      {%- for block in section.blocks -%}
        <li class="arenus-cap-tabs__item" {{ block.shopify_attributes }}>
          <a class="arenus-cap-tabs__tile" href="{{ block.settings.link | default: '#' }}">
            <span class="arenus-cap-tabs__icon" aria-hidden="true">
              {%- case block.settings.icon -%}
                {%- when 'overview' -%}
                  <svg width="28" height="28" viewBox="0 0 24 24" fill="none"><path d="M4 5.5C4 4.67157 4.67157 4 5.5 4H11V20H5.5C4.67157 20 4 19.3284 4 18.5V5.5Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M20 5.5C20 4.67157 19.3284 4 18.5 4H13V20H18.5C19.3284 20 20 19.3284 20 18.5V5.5Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg>
                {%- when 'faq' -%}
                  <svg width="28" height="28" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.5"/><path d="M9.5 9.5C9.5 8.11929 10.6193 7 12 7C13.3807 7 14.5 8.11929 14.5 9.5C14.5 10.5 14 11 13 11.75C12.25 12.25 12 13 12 13.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><circle cx="12" cy="16.5" r="0.9" fill="currentColor"/></svg>
                {%- when 'enroll' -%}
                  <svg width="28" height="28" viewBox="0 0 24 24" fill="none"><path d="M6 3H14L19 8V21H6V3Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M14 3V8H19" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M9 13H16M9 17H14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                {%- when 'wellness' -%}
                  <svg width="28" height="28" viewBox="0 0 24 24" fill="none"><path d="M12 21C12 21 3.5 15 3.5 9.5C3.5 6.46243 5.96243 4 9 4C10.5 4 12 5 12 5C12 5 13.5 4 15 4C18.0376 4 20.5 6.46243 20.5 9.5C20.5 15 12 21 12 21Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg>
                {%- when 'claim' -%}
                  <svg width="28" height="28" viewBox="0 0 24 24" fill="none"><path d="M8 4H16V6H19V21H5V6H8V4Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M9 11L11 13L15 9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M9 3H15V6H9V3Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg>
                {%- when 'report' -%}
                  <svg width="28" height="28" viewBox="0 0 24 24" fill="none"><path d="M4 14V10C4 9.44772 4.44772 9 5 9H9L18 5V19L9 15H5C4.44772 15 4 14.5523 4 14Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M18 5V19" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                {%- when 'terms' -%}
                  <svg width="28" height="28" viewBox="0 0 24 24" fill="none"><path d="M5 4H17V20C17 20.5523 17.4477 21 18 21H7C5.89543 21 5 20.1046 5 19V4Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M17 4H19C20.1046 4 21 4.89543 21 6V19C21 20.1046 20.1046 21 19 21H18C17.4477 21 17 20.5523 17 20V4Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M9 9H13M9 13H13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                {%- when 'number-1' -%}
                  <span class="arenus-cap-tabs__num">1</span>
                {%- when 'number-2' -%}
                  <span class="arenus-cap-tabs__num">2</span>
                {%- when 'number-3' -%}
                  <span class="arenus-cap-tabs__num">3</span>
                {%- when 'number-4' -%}
                  <span class="arenus-cap-tabs__num">4</span>
                {%- else -%}
                  <svg width="28" height="28" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.5"/><path d="M12 8V12L14.5 14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
              {%- endcase -%}
            </span>
            <span class="arenus-cap-tabs__label">{{ block.settings.label }}</span>
          </a>
        </li>
      {%- endfor -%}
    </ul>
  {%- endif -%}
</section>

{% stylesheet %}
  /* ═══════════════════════════════════════════
     Arenus CAP Tabs — Mobile-first
     ═══════════════════════════════════════════ */
  .arenus-cap-tabs {
    margin: 0 auto;
    max-width: 1440px;
    padding-inline: 20px;
  }

  .arenus-cap-tabs__heading {
    font-family: var(--font-heading--family);
    font-style: var(--font-heading--style);
    font-weight: 400;
    font-size: 28px;
    line-height: 1.1;
    letter-spacing: -0.56px;
    color: #000;
    margin: 0 0 24px;
    text-align: center;
  }

  .arenus-cap-tabs__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
  }

  .arenus-cap-tabs__item {
    margin: 0;
    padding: 0;
  }

  .arenus-cap-tabs__tile { 
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 10px;
    border: 1px solid #191919;
    border-radius: 6px;
    background: #ffffff;
    text-decoration: none;
    color: #191919;
    text-align: center;
    transition: border-color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
    cursor: pointer;
    height: 100%;
  }

  .arenus-cap-tabs__tile:hover {
    border-color: #e6b236;
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(230, 178, 54, 0.15);
  }

  .arenus-cap-tabs__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: #fff8e0;
    color: #191919;
    transition: background 0.2s ease;
  }

  .arenus-cap-tabs__icon svg {
    width: 20px;
    height: 20px;
  }

  .arenus-cap-tabs__num {
    font-family: var(--font-heading--family);
    font-style: var(--font-heading--style);
    font-weight: 400;
    font-size: 22px;
    line-height: 1;
    color: #191919;
  }

  .arenus-cap-tabs__tile:hover .arenus-cap-tabs__icon {
    background: #e6b236;
    color: #ffffff;
  }

  .arenus-cap-tabs__tile:hover .arenus-cap-tabs__num {
    color: #ffffff;
  }

  .arenus-cap-tabs__label {
    font-family: var(--font-body--family);
    font-weight: 500;
    font-size: 12px;
    line-height: 1.3;
    letter-spacing: -0.12px;
    color: #191919;
    text-transform: uppercase;
  }

  @media screen and (min-width: 750px) {
    .arenus-cap-tabs {
      padding-inline: 40px;
    }

    .arenus-cap-tabs__heading {
      font-size: 40px;
      letter-spacing: -0.8px;
      margin-bottom: 40px;
    }

    .arenus-cap-tabs__grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 20px;
    }

    .arenus-cap-tabs__tile {
      padding: 16px;
      gap: 10px;
    }

    .arenus-cap-tabs__icon {
      width: 56px;
      height: 56px;
    }

    .arenus-cap-tabs__icon svg {
      width: 28px;
      height: 28px;
    }

    .arenus-cap-tabs__num {
      font-size: 30px;
    }

    .arenus-cap-tabs__label {
      font-size: 14px;
      letter-spacing: -0.14px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "CAP Tabs",
  "tag": "section",
  "class": "arenus-cap-tabs-wrapper section-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Explore the Program"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "tab",
      "name": "Tab",
      "limit": 12,
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Overview"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "overview", "label": "Overview (book)" },
            { "value": "faq", "label": "FAQ (question)" },
            { "value": "enroll", "label": "Enroll (document)" },
            { "value": "wellness", "label": "Wellness (heart)" },
            { "value": "claim", "label": "Claim (clipboard)" },
            { "value": "report", "label": "Report (megaphone)" },
            { "value": "terms", "label": "Terms (scroll)" },
            { "value": "number-1", "label": "Number 1" },
            { "value": "number-2", "label": "Number 2" },
            { "value": "number-3", "label": "Number 3" },
            { "value": "number-4", "label": "Number 4" },
            { "value": "default", "label": "Default (info)" }
          ],
          "default": "overview"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "CAP Tabs",
      "category": "Arenus",
      "blocks": [
        { "type": "tab", "settings": { "label": "Overview", "icon": "overview" } },
        { "type": "tab", "settings": { "label": "FAQ", "icon": "faq" } },
        { "type": "tab", "settings": { "label": "Enroll Now", "icon": "enroll" } },
        { "type": "tab", "settings": { "label": "Wellness Programs", "icon": "wellness" } },
        { "type": "tab", "settings": { "label": "File a Claim", "icon": "claim" } },
        { "type": "tab", "settings": { "label": "Report", "icon": "report" } },
        { "type": "tab", "settings": { "label": "Terms & Conditions", "icon": "terms" } }
      ]
    }
  ],
  "templates": ["page"]
}
{% endschema %}
