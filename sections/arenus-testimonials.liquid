<div
  id="ArenusTestimonials-{{ section.id }}"
  class="arenus-testimonials c-page-width"
  style="
    --arenus-testimonials-bg: {{ section.settings.background_color }};
    --arenus-testimonials-text: {{ section.settings.text_color }};
    --arenus-testimonials-border: {{ section.settings.card_border_color }};
    padding-block-start: {{ section.settings.padding-block-start }}px;
    padding-block-end: {{ section.settings.padding-block-end }}px;
  "
>
  <div class="arenus-testimonials__header">
    {%- if section.settings.heading != blank -%}
      <h2 class="arenus-testimonials__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    {%- if section.blocks.size > 1 -%}
      <div class="arenus-testimonials__nav">
        <button
          type="button"
          class="arenus-testimonials__nav-btn arenus-testimonials__nav-btn--prev"
          aria-label="Previous testimonial"
          data-direction="prev"
        >
          {% render 'icon-caret-left' %}
        </button>
        <button
          type="button"
          class="arenus-testimonials__nav-btn arenus-testimonials__nav-btn--next"
          aria-label="Next testimonial"
          data-direction="next"
        >
          {% render 'icon-caret-right' %}
        </button>
      </div>
    {%- endif -%}
  </div>

  {%- if section.blocks.size > 0 -%}
    <div class="arenus-testimonials__carousel">
      <div class="arenus-testimonials__track">
        {%- for block in section.blocks -%}
          <div class="arenus-testimonials__card" {{ block.shopify_attributes }}>
            {%- comment -%} Stars {%- endcomment -%}
            <div class="arenus-testimonials__stars" aria-label="5 out of 5 stars">
              {%- for i in (1..5) -%}
                {% render 'icon-star' %}
              {%- endfor -%}
            </div>

            {%- comment -%} Review text {%- endcomment -%}
            {%- if block.settings.review_text != blank -%}
              <p class="arenus-testimonials__review">{{ block.settings.review_text }}</p>
            {%- endif -%}

            {%- comment -%} Author name {%- endcomment -%}
            {%- if block.settings.author_name != blank -%}
              <p class="arenus-testimonials__author">{{ block.settings.author_name }}</p>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}
</div>

{% stylesheet %}
  /* ===== Arenus Testimonials — Mobile-first ===== */

  .arenus-testimonials {
    background-color: var(--arenus-testimonials-bg, #ffffff);
    color: var(--arenus-testimonials-text, #000000);
    display: flex;
    flex-direction: column;
    gap: 20px;
    margin: 0 auto;
    max-width: 1440px;
  }

  /* Header row */
  .arenus-testimonials__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-inline: 20px;
  }

  /* Section heading */
  .arenus-testimonials__heading {
    font-family: var(--font-heading--family);
    font-style: var(--font-heading--style);
    font-weight: var(--font-heading--weight);
    font-size: 32px;
    line-height: 1.1;
    letter-spacing: -0.64px;
    margin: 0;
  }

  /* Navigation buttons — hidden on mobile */
  .arenus-testimonials__nav {
    display: none;
  }

  /* Carousel container */
  .arenus-testimonials__carousel {
    overflow: hidden;
  }

  /* Scrollable track */
  .arenus-testimonials__track {
    display: flex;
    gap: 16px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;

    /* Hide scrollbar but keep functionality */
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .arenus-testimonials__track::-webkit-scrollbar {
    display: none;
  }

  /* Individual card */
  .arenus-testimonials__card {
    flex: 0 0 344px;
    scroll-snap-align: center;
    border: 1px solid var(--arenus-testimonials-border, #dddddd);
    border-radius: 12px;
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .arenus-testimonials__card:first-child {
    margin-left: 20px;
  }

  .arenus-testimonials__card:last-child {
    margin-right: 20px;
  }

  

  /* Stars row */
  .arenus-testimonials__stars {
    display: flex;
    align-items: center;
    gap: 0;
  }

  .arenus-testimonials__stars svg {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
  }

  /* Review text */
  .arenus-testimonials__review {
    font-family: var(--font-body--family);
    font-weight: var(--font-body--weight);
    font-size: 14px;
    line-height: 1.5;
    letter-spacing: -0.14px;
    margin: 0;
  }

  /* Author name */
  .arenus-testimonials__author {
    font-family: var(--font-body--family);
    font-weight: 700;
    font-size: 14px;
    line-height: 1;
    text-transform: uppercase;
    margin: 0;
  }

  /* ===== Desktop ===== */
  @media screen and (min-width: 750px) {
    .arenus-testimonials {
      gap: 32px;
      padding-inline: 40px;
    }

    .arenus-testimonials__header {
      padding-inline: 0;
    }

    .arenus-testimonials__nav {
      display: flex;
      align-items: center;
      gap: 0;
    }

    .arenus-testimonials__nav-btn {
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 8px;
      border: none;
      border-radius: 100px;
      background: transparent;
      cursor: pointer;
      color: inherit;
      transition: opacity 0.2s ease;
    }

    .arenus-testimonials__nav-btn:hover {
      opacity: 0.6;
    }

    .arenus-testimonials__nav-btn svg {
      width: 24px;
      height: 24px;
    }

    .arenus-testimonials__track {
      gap: 20px;
    }

    .arenus-testimonials__card {
      flex: 0 0 394px;
    }

    .arenus-testimonials__card:first-child {
      margin-left: 0;
    }

    .arenus-testimonials__card:last-child {
      margin-right: 0;
    }
  }
{% endstylesheet %}

{% javascript %}
  function initArenusTestimonials() {
    var sections = document.querySelectorAll('.arenus-testimonials');

    sections.forEach(function(section) {
      var track = section.querySelector('.arenus-testimonials__track');
      var prevBtn = section.querySelector('.arenus-testimonials__nav-btn--prev');
      var nextBtn = section.querySelector('.arenus-testimonials__nav-btn--next');

      if (!track || !prevBtn || !nextBtn) return;

      function getCardWidth() {
        var card = track.querySelector('.arenus-testimonials__card');
        if (!card) return 0;
        var style = window.getComputedStyle(track);
        var gap = parseFloat(style.columnGap) || 0;
        return card.offsetWidth + gap;
      }

      prevBtn.addEventListener('click', function() {
        track.scrollBy({ left: -getCardWidth(), behavior: 'smooth' });
      });

      nextBtn.addEventListener('click', function() {
        track.scrollBy({ left: getCardWidth(), behavior: 'smooth' });
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initArenusTestimonials);
  } else {
    initArenusTestimonials();
  }
{% endjavascript %}

