{%- comment -%}
  Arenus Customer Reset Password.
  Form to set a new password (accessed from the email reset link).
{%- endcomment -%}

<div class="arenus-auth" style="--auth-accent: #E6B236;">
  <div class="arenus-auth__form-col arenus-auth__form-col--centered">

    <h1 class="arenus-auth__centered-title">
      {{ 'content.customer_reset_title' | t }}
    </h1>

    {%- form 'reset_customer_password' -%}
      {%- if form.errors -%}
        <div class="arenus-auth__errors" role="alert">
          <p>{{ form.errors | default_errors }}</p>
        </div>
      {%- endif -%}

      <div class="arenus-auth__field">
        <label class="arenus-auth__label" for="ResetPassword">
          {{ 'content.customer_password_label' | t }}
        </label>
        <input
          type="password"
          id="ResetPassword"
          name="customer[password]"
          class="arenus-auth__input"
          autocomplete="new-password"
          required
        />
      </div>

      <div class="arenus-auth__field">
        <label class="arenus-auth__label" for="ResetPasswordConfirm">
          {{ 'content.customer_password_confirm_label' | t }}
        </label>
        <input
          type="password"
          id="ResetPasswordConfirm"
          name="customer[password_confirmation]"
          class="arenus-auth__input"
          autocomplete="new-password"
          required
        />
      </div>

      <button type="submit" class="arenus-auth__btn">
        {{ 'actions.reset_password' | t }}
      </button>
    {%- endform -%}

  </div>
</div>

{% stylesheet %}
  .arenus-auth__form-col--centered {
    max-width: 480px;
    margin: 0 auto;
    padding: 40px 20px;
  }

  .arenus-auth__centered-title {
    font-family: var(--font-heading--family);
    font-style: var(--font-heading--style);
    font-weight: var(--font-heading--weight);
    font-size: 24px;
    line-height: 1.2;
    margin: 0 0 32px;
  }

  @media screen and (min-width: 750px) {
    .arenus-auth__form-col--centered {
      padding: 60px 20px;
    }

    .arenus-auth__centered-title {
      font-size: 32px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Customer Reset Password",
  "tag": "section",
  "class": "arenus-auth-wrapper section-wrapper"
}
{% endschema %}
