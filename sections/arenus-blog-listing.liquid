{%- comment -%}
  Arenus Blog Listing — full blog page with AJAX tag filtering
  (fetches section HTML via ?section_id= like the collection page),
  client-side sorting, and "Load More" progressive reveal.
  Uses the `blog` global object from the blog template.
  Filter buttons are schema blocks.
{%- endcomment -%}

{%- liquid
  assign initial_count = section.settings.posts_per_load | default: 6
  assign active_tag = current_tags | first | handleize
-%}

{%- comment -%} ═══ Breadcrumb ═══ {%- endcomment -%}
<nav class="arenus-blst__breadcrumb" aria-label="Breadcrumb">
  <a href="/" class="arenus-blst__breadcrumb-back">
    <svg width="12" height="12" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <path d="M7.5 9L4.5 6L7.5 3" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
    <span>Home</span>
  </a>
  <span class="arenus-blst__breadcrumb-trail">
    <a href="/" class="arenus-blst__breadcrumb-link">Home</a>
    <svg width="12" height="12" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <path d="M4.5 3L7.5 6L4.5 9" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
    <span class="arenus-blst__breadcrumb-current">Blog</span>
  </span>
</nav>

<div
  id="ArenusBlogListing-{{ section.id }}"
  class="arenus-blst"
  data-arenus-blst
  data-blog-handle="{{ blog.handle }}"
  data-initial-count="{{ initial_count }}"
  data-active-tag="{{ active_tag }}"
>
  {%- comment -%} ═══ Header: heading + filters + sort ═══ {%- endcomment -%}
  <div class="arenus-blst__header">
    {%- if section.settings.heading != blank -%}
      <h1 class="arenus-blst__heading">{{ section.settings.heading }}</h1>
    {%- endif -%}

    <div class="arenus-blst__toolbar">
      {%- comment -%} Filter buttons — AJAX via section rendering {%- endcomment -%}
      <div class="arenus-blst__filters" data-blst-filters role="group" aria-label="Filter articles">
        {%- for block in section.blocks -%}
          {%- liquid
            assign tag_handle = block.settings.tag | handleize
            assign is_view_all = false
            if block.settings.tag == blank
              assign is_view_all = true
            endif

            assign is_active = false
            if is_view_all and active_tag == blank
              assign is_active = true
            endif
            if is_view_all == false and active_tag == tag_handle
              assign is_active = true
            endif
          -%}
          <button
            type="button"
            class="arenus-blst__filter-btn{% if is_active %} is-active{% endif %}"
            data-tag="{{ tag_handle }}"
            {{ block.shopify_attributes }}
          >
            {{ block.settings.label }}
          </button>
        {%- endfor -%}
      </div>

      {%- comment -%} Sort dropdown — client-side {%- endcomment -%}
      <div class="arenus-blst__sort">
        <select class="arenus-blst__sort-select" data-blst-sort aria-label="Sort articles">
          <option value="recent">Most Recent</option>
          <option value="oldest">Oldest First</option>
          <option value="az">A-Z</option>
          <option value="za">Z-A</option>
        </select>
        <svg class="arenus-blst__sort-caret" width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M5 7.5L10 12.5L15 7.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
    </div>
  </div>

  {%- comment -%} ═══ Articles grid wrapper ═══ {%- endcomment -%}
  <div class="arenus-blst__grid-wrapper" data-blst-grid-wrapper>
    <div class="arenus-blst__grid" data-blst-grid>
      {%- paginate blog.articles by 50 -%}
        {%- for article in blog.articles -%}
          {%- liquid
            assign first_tag = article.tags | first
          -%}
          <a
            href="{{ article.url }}"
            class="arenus-blst__card"
            data-blst-card
            data-date="{{ article.published_at | date: '%s' }}"
            data-title="{{ article.title | escape }}"
          >
            <div class="arenus-blst__card-image">
              {%- if article.image -%}
                {{
                  article.image
                  | image_url: width: 900
                  | image_tag:
                    width: article.image.width,
                    widths: '353, 440, 600, 900',
                    height: article.image.height,
                    alt: article.title,
                    class: 'arenus-blst__card-img',
                    sizes: '(min-width: 750px) 440px, calc(100vw - 40px)',
                    loading: 'lazy'
                }}
              {%- endif -%}
            </div>
            <div class="arenus-blst__card-info">
              {%- if first_tag != blank -%}
                <span class="arenus-blst__card-tag">{{ first_tag }}</span>
              {%- endif -%}
              <h2 class="arenus-blst__card-title">{{ article.title }}</h2>
            </div>
          </a>
        {%- endfor -%}
      {%- endpaginate -%}
    </div>

    {%- comment -%} Load More button {%- endcomment -%}
    <div class="arenus-blst__load-more-wrap" data-blst-load-more-wrap>
      <button type="button" class="arenus-blst__load-more-btn" data-blst-load-more>
        LOAD MORE
      </button>
    </div>
  </div>
</div>

<script>
  (function() {
    var root = document.querySelector('[data-arenus-blst]');
    if (!root) return;

    var blogHandle = root.getAttribute('data-blog-handle');
    var initialCount = parseInt(root.getAttribute('data-initial-count'), 10) || 6;
    var filtersRow = root.querySelector('[data-blst-filters]');
    var gridWrapper = root.querySelector('[data-blst-grid-wrapper]');
    var sortSelect = root.querySelector('[data-blst-sort]');

    var currentTag = root.getAttribute('data-active-tag') || '';
    var isFetching = false;
    var visibleCount = initialCount;

    var rootUrl = (window.Shopify && window.Shopify.routes && window.Shopify.routes.root) || '/';
    if (rootUrl.charAt(rootUrl.length - 1) !== '/') rootUrl += '/';

    function buildUrl(tag) {
      var url = rootUrl + 'blogs/' + blogHandle;
      if (tag) url += '/tagged/' + tag;
      url += '?section_id=arenus-blog-listing';
      return url;
    }

    function getCards() {
      return Array.from(root.querySelectorAll('[data-blst-card]'));
    }

    function sortCards(arr) {
      var val = sortSelect ? sortSelect.value : 'recent';
      var sorted = arr.slice();
      if (val === 'recent') {
        sorted.sort(function(a, b) {
          return parseInt(b.getAttribute('data-date'), 10) - parseInt(a.getAttribute('data-date'), 10);
        });
      } else if (val === 'oldest') {
        sorted.sort(function(a, b) {
          return parseInt(a.getAttribute('data-date'), 10) - parseInt(b.getAttribute('data-date'), 10);
        });
      } else if (val === 'az') {
        sorted.sort(function(a, b) {
          return (a.getAttribute('data-title') || '').localeCompare(b.getAttribute('data-title') || '');
        });
      } else if (val === 'za') {
        sorted.sort(function(a, b) {
          return (b.getAttribute('data-title') || '').localeCompare(a.getAttribute('data-title') || '');
        });
      }
      return sorted;
    }

    function renderVisibility() {
      var cards = getCards();
      var sorted = sortCards(cards);
      var loadMoreWrap = root.querySelector('[data-blst-load-more-wrap]');

      cards.forEach(function(c) { c.style.display = 'none'; c.style.order = ''; });
      sorted.forEach(function(card, i) {
        if (i < visibleCount) card.style.display = '';
        card.style.order = i;
      });

      if (loadMoreWrap) {
        loadMoreWrap.style.display = sorted.length > visibleCount ? '' : 'none';
      }
    }

    function fetchFiltered(tag) {
      if (isFetching) return;
      isFetching = true;
      filtersRow.classList.add('is-loading');

      fetch(buildUrl(tag))
        .then(function(res) { return res.text(); })
        .then(function(html) {
          var tmp = document.createElement('div');
          tmp.innerHTML = html;
          var newWrapper = tmp.querySelector('[data-blst-grid-wrapper]');

          if (newWrapper && gridWrapper) {
            gridWrapper.innerHTML = newWrapper.innerHTML;
          }

          visibleCount = initialCount;

          bindLoadMore();
          renderVisibility();

          /* Update URL without reload */
          var newUrl = rootUrl + 'blogs/' + blogHandle;
          if (tag) newUrl += '/tagged/' + tag;
          history.replaceState(null, '', newUrl);

          isFetching = false;
          filtersRow.classList.remove('is-loading');
        })
        .catch(function(err) {
          console.error('[blog-listing] Filter fetch error:', err);
          isFetching = false;
          filtersRow.classList.remove('is-loading');
        });
    }

    /* --- Filter click --- */
    if (filtersRow) {
      filtersRow.addEventListener('click', function(e) {
        var btn = e.target.closest('.arenus-blst__filter-btn');
        if (!btn || isFetching) return;

        var tag = btn.getAttribute('data-tag') || '';
        if (tag === currentTag) return;

        filtersRow.querySelectorAll('.arenus-blst__filter-btn').forEach(function(b) { b.classList.remove('is-active'); });
        btn.classList.add('is-active');

        currentTag = tag;
        fetchFiltered(tag);
      });
    }

    /* --- Sort change --- */
    if (sortSelect) {
      sortSelect.addEventListener('change', function() { renderVisibility(); });
    }

    /* --- Load More --- */
    function bindLoadMore() {
      var btn = root.querySelector('[data-blst-load-more]');
      if (!btn) return;
      btn.addEventListener('click', function() {
        visibleCount += initialCount;
        renderVisibility();
      });
    }

    bindLoadMore();
    renderVisibility();
  })();
</script>

{% stylesheet %}
  /* ===== Arenus Blog Listing — Mobile-first ===== */

  /* ── Breadcrumb ── */
  .arenus-blst__breadcrumb {
    display: flex;
    align-items: center;
    padding: 16px 20px;
    font-family: var(--font-body--family);
    font-weight: var(--font-body--weight);
    font-size: 12px;
    line-height: 1.4;
    letter-spacing: -0.12px;
    color: #808085;
  }

  .arenus-blst__breadcrumb-link {
    color: #000;
    text-decoration: none;
  }

  .arenus-blst__breadcrumb-link:hover {
    text-decoration: underline;
  }

  .arenus-blst__breadcrumb-back {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: #808085;
    text-decoration: none;
  }

  .arenus-blst__breadcrumb-trail {
    display: none;
    align-items: center;
    gap: 0;
  }

  .arenus-blst__breadcrumb-trail svg {
    margin: 0 8px;
    flex-shrink: 0;
  }

  .arenus-blst__breadcrumb-current {
    color: #000;
    max-width: 140px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    display: inline-block;
    vertical-align: middle;
  }

  /* ── Main container ── */
  .arenus-blst {
    padding: 0 20px 40px;
  }

  /* ── Header ── */
  .arenus-blst__header {
    margin-bottom: 20px;
  }

  .arenus-blst__heading {
    font-family: var(--font-heading--family);
    font-style: var(--font-heading--style);
    font-weight: var(--font-heading--weight);
    font-size: 32px;
    line-height: 1.1;
    letter-spacing: -0.64px;
    color: #000;
    margin: 0 0 32px;
  }

  /* ── Toolbar (filters + sort) ── */
  .arenus-blst__toolbar {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  /* ── Filters (matches collection page pattern) ── */
  .arenus-blst__filters {
    display: flex;
    gap: 12px;
    overflow-x: auto;
    flex-wrap: nowrap;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .arenus-blst__filters::-webkit-scrollbar {
    display: none;
  }

  .arenus-blst__filters.is-loading {
    opacity: 0.5;
    pointer-events: none;
  }

  .arenus-blst__filter-btn {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 4px;
    padding: 12px 20px;
    background-color: #f9f9f9;
    color: #000000;
    border: 1px solid transparent;
    border-radius: 6px;
    font-family: var(--font-body--family);
    font-weight: 500;
    font-size: 14px;
    line-height: 1;
    text-transform: uppercase;
    letter-spacing: 0;
    cursor: pointer;
    white-space: nowrap;
    transition: background-color 0.15s ease, border-color 0.15s ease;
    box-sizing: border-box;
  }

  .arenus-blst__filter-btn:hover {
    border-color: #000000;
  }

  .arenus-blst__filter-btn:first-child {
    margin-left: 20px;
  }

  .arenus-blst__filter-btn:last-child {
    margin-right: 20px;
  }

  .arenus-blst__filter-btn.is-active {
    background-color: #ffffff;
    border-color: #000000;
  }

  /* ── Sort dropdown ── */
  .arenus-blst__sort {
    position: relative;
    width: 100%;
  }

  .arenus-blst__sort-select {
    width: 100%;
    height: 38px;
    padding: 0 40px 0 16px;
    font-family: var(--font-body--family);
    font-weight: var(--font-body--weight);
    font-size: 16px;
    line-height: 1.4;
    letter-spacing: -0.32px;
    color: #808085;
    background: #fff;
    border: 1px solid #DDDDDD;
    border-radius: 6px;
    appearance: none;
    cursor: pointer;
    box-sizing: border-box;
  }

  .arenus-blst__sort-caret {
    position: absolute;
    right: 16px;
    top: 50%;
    transform: translateY(-50%);
    pointer-events: none;
    color: #808085;
  }

  /* ── Article grid ── */
  .arenus-blst__grid {
    display: flex;
    flex-wrap: wrap;
    gap: 20px;
  }

  /* ── Article card ── */
  .arenus-blst__card {
    display: flex;
    flex-direction: column;
    gap: 20px;
    text-decoration: none;
    color: inherit;
    width: 100%;
  }

  .arenus-blst__card-image {
    width: 100%;
    height: 232px;
    border-radius: 12px;
    overflow: hidden;
    background-color: #F9F9F9;
  }

  .arenus-blst__card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .arenus-blst__card-info {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .arenus-blst__card-title {
    font-family: var(--font-body--family);
    font-weight: var(--font-body--weight);
    font-size: 20px;
    line-height: 1.4;
    letter-spacing: -0.4px;
    color: #000;
    margin: 0;
  }

  .arenus-blst__card-tag {
    font-family: var(--font-body--family);
    font-weight: var(--font-body--weight);
    font-size: 12px;
    line-height: 1.4;
    letter-spacing: -0.12px;
    color: #808085;
  }

  /* ── Load More ── */
  .arenus-blst__load-more-wrap {
    display: flex;
    justify-content: center;
    padding: 20px 0 0;
  }

  .arenus-blst__load-more-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    padding: 12px 24px;
    font-family: var(--font-body--family);
    font-weight: 500;
    font-size: 14px;
    line-height: 1;
    letter-spacing: 0;
    text-transform: uppercase;
    color: #000;
    background: transparent;
    border: 1px solid #000;
    border-radius: 6px;
    cursor: pointer;
    transition: background-color 0.15s, color 0.15s;
    box-sizing: border-box;
  }

  .arenus-blst__load-more-btn:hover {
    background-color: #000;
    color: #fff;
  }

  /* ===== Desktop ===== */
  @media screen and (min-width: 750px) {
    .arenus-blst__breadcrumb {
      padding: 16px 40px;
    }

    .arenus-blst__breadcrumb-back {
      display: none;
    }

    .arenus-blst__breadcrumb-trail {
      display: inline-flex;
    }

    .arenus-blst {
      padding: 0 40px 40px;
    }

    .arenus-blst__heading {
      font-size: 56px;
      line-height: 1;
      letter-spacing: -0.8px;
      max-width: 840px;
      margin-bottom: 32px;
    }

    .arenus-blst__toolbar {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }

    .arenus-blst__filter-btn:first-child {
      margin-left: 0;
    }

    .arenus-blst__filter-btn:last-child {
      margin-right: 0;
    }

    .arenus-blst__sort {
      width: 166px;
      flex-shrink: 0;
    }

    .arenus-blst__grid {
      padding-top: 40px;
    }

    .arenus-blst__card {
      width: calc((100% - 40px) / 3);
    }

    .arenus-blst__card-image {
      height: 292px;
    }

    .arenus-blst__load-more-wrap {
      padding-top: 40px;
    }

    .arenus-blst__load-more-btn {
      width: 218px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Blog Listing",
  "tag": "section",
  "class": "arenus-blst-wrapper section-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "In-depth information on feeding, management, and testing"
    },
    {
      "type": "range",
      "id": "posts_per_load",
      "label": "Posts shown before Load More",
      "min": 3,
      "max": 50,
      "step": 1,
      "default": 50
    }
  ],
  "blocks": [
    {
      "type": "filter",
      "name": "Filter button",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Button label",
          "default": "View All"
        },
        {
          "type": "text",
          "id": "tag",
          "label": "Tag to filter by",
          "info": "Leave empty for \"View All\" (shows all posts). Use the tag handle, e.g. gut-health"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Blog Listing",
      "category": "Blog",
      "settings": {
        "heading": "In-depth information on feeding, management, and testing",
        "posts_per_load": 50
      },
      "blocks": [
        {
          "type": "filter",
          "settings": {
            "label": "View All",
            "tag": ""
          }
        },
        {
          "type": "filter",
          "settings": {
            "label": "Gut Health",
            "tag": "gut-health"
          }
        },
        {
          "type": "filter",
          "settings": {
            "label": "Breathing",
            "tag": "breathing"
          }
        },
        {
          "type": "filter",
          "settings": {
            "label": "Joint & Mobility",
            "tag": "joint-mobility"
          }
        },
        {
          "type": "filter",
          "settings": {
            "label": "Performance",
            "tag": "performance"
          }
        },
        {
          "type": "filter",
          "settings": {
            "label": "Brands We Trust",
            "tag": "brands-we-trust"
          }
        }
      ]
    }
  ]
}
{% endschema %}
