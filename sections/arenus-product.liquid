{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign short_desc = product.metafields.custom.short_description
  assign ingredients_meta = product.metafields.custom.ingredients
  assign how_to_use_meta = product.metafields.custom.how_to_use
-%}

{%- comment -%} ── Breadcrumbs ── {%- endcomment -%}
{%- if section.settings.show_breadcrumbs -%}
  <nav class="arenus-product-breadcrumbs" aria-label="Breadcrumb">
    <div class="arenus-product-breadcrumbs__inner">
      {%- comment -%} Mobile: back link {%- endcomment -%}
      <a class="arenus-product-breadcrumbs__back" href="{{ collections.all.url }}">
        <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M7.5 9L4.5 6L7.5 3" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        Shop All
      </a>

      {%- comment -%} Desktop: full trail {%- endcomment -%}
      <ol class="arenus-product-breadcrumbs__trail">
        <li><a href="/">Home</a></li>
        <li>
          <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M4.5 3L7.5 6L4.5 9" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          <span aria-current="page">{{ product.title }}</span>
        </li>
      </ol>
    </div>
  </nav>
{%- endif -%}

{%- comment -%} ══════════ MAIN SECTION ══════════ {%- endcomment -%}
<section
  class="arenus-product"
  data-section-id="{{ section.id }}"
  data-product-url="{{ product.url }}"
>
  <div class="arenus-product__inner c-page-width">
    <div class="arenus-product__grid">

      {%- comment -%} ── LEFT: Media column ── {%- endcomment -%}
      <div class="arenus-product__media-col">
        {%- for block in section.blocks -%}
          {%- if block.type == 'media' -%}
            <div
              class="arenus-product__media"
              style="--arenus-product-image-bg: {{ settings.product_card_image_bg }};"
              {{ block.shopify_attributes }}
            >
              {%- comment -%} Desktop thumbnails {%- endcomment -%}
              <div class="arenus-product__thumbnails" data-thumbnails>
                {%- for media in product.media -%}
                  {%- assign thumb_src = media.preview_image | image_url: width: 168 -%}
                  <button
                    type="button"
                    class="arenus-product__thumb{% if forloop.first %} arenus-product__thumb--active{% endif %}"
                    data-thumb-index="{{ forloop.index0 }}"
                    data-media-type="{{ media.media_type }}"
                    aria-label="View {% if media.media_type contains 'video' %}video{% else %}image{% endif %} {{ forloop.index }}"
                  >
                    <img
                      src="{{ thumb_src }}"
                      alt="{{ media.alt | escape }}"
                      width="76"
                      height="76"
                      loading="{% if forloop.index <= 5 %}eager{% else %}lazy{% endif %}"
                    >
                    {%- if media.media_type contains 'video' -%}
                      <span class="arenus-product__thumb-video-icon" aria-hidden="true">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
                      </span>
                    {%- endif -%}
                  </button>
                {%- endfor -%}
              </div>

              {%- comment -%} Main carousel {%- endcomment -%}
              <div class="arenus-product__carousel-wrap">
                <div class="arenus-product__carousel" data-carousel>
                  {%- for media in product.media -%}
                    <div class="arenus-product__slide" data-slide-index="{{ forloop.index0 }}" data-media-type="{{ media.media_type }}">
                      <div class="arenus-product__slide-bg-color">
                        {%- case media.media_type -%}
                          {%- when 'video' -%}
                            {%- comment -%} Shopify-hosted video with multiple sources {%- endcomment -%}
                            <video
                              class="arenus-product__slide-video"
                              controls
                              playsinline
                              preload="{% if forloop.first %}metadata{% else %}none{% endif %}"
                              poster="{{ media.preview_image | image_url: width: 1200 }}"
                            >
                              {%- for source in media.sources -%}
                                <source src="{{ source.url }}" type="{{ source.mime_type }}">
                              {%- endfor -%}
                            </video>
                          {%- when 'external_video' -%}
                            {%- comment -%} External video (YouTube/Vimeo) {%- endcomment -%}
                            <div class="arenus-product__slide-video-wrap">
                              {%- if media.host == 'youtube' -%}
                                <iframe
                                  src="https://www.youtube.com/embed/{{ media.external_id }}?rel=0&playsinline=1"
                                  class="arenus-product__slide-video"
                                  title="{{ media.alt | escape }}"
                                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                                  allowfullscreen
                                  loading="lazy"
                                ></iframe>
                              {%- elsif media.host == 'vimeo' -%}
                                <iframe
                                  src="https://player.vimeo.com/video/{{ media.external_id }}?playsinline=1"
                                  class="arenus-product__slide-video"
                                  title="{{ media.alt | escape }}"
                                  allow="autoplay; fullscreen; picture-in-picture"
                                  allowfullscreen
                                  loading="lazy"
                                ></iframe>
                              {%- endif -%}
                            </div>
                          {%- else -%}
                            {% assign image_width = media.width | times: 2 %}
                            <img
                              src="{{ media | image_url: width: image_width }}"
                              alt="{{ media.alt | escape }}"
                              width="{{ image_width }}"
                              height="{{ image_width }}"
                              loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                              data-media-image
                            >
                        {%- endcase -%}
                      </div>
                    </div>
                  {%- endfor -%}
                </div>

                {%- comment -%} Mobile dots {%- endcomment -%}
                {%- if product.media.size > 1 -%}
                  <div class="arenus-product__dots" data-dots>
                    {%- for media in product.media -%}
                      <button
                        type="button"
                        class="arenus-product__dot{% if forloop.first %} arenus-product__dot--active{% endif %}"
                        data-dot-index="{{ forloop.index0 }}"
                        aria-label="Go to image {{ forloop.index }}"
                      ></button>
                    {%- endfor -%}
                  </div>
                {%- endif -%}
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}

        {%- comment -%} ── IMAGES LIGHTBOX MODAL ── {%- endcomment -%}
        {%- if product.media.size > 0 -%}
          <dialog class="arenus-product__lightbox" data-lightbox aria-label="Product images">
            <button type="button" class="arenus-product__lightbox-close" data-lightbox-close aria-label="Close gallery">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M6 6l12 12M18 6L6 18" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
            </button>
            {%- if product.media.size > 1 -%}
              <button type="button" class="arenus-product__lightbox-nav arenus-product__lightbox-nav--prev" data-lightbox-prev aria-label="Previous image">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M15 6L9 12L15 18" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </button>
              <button type="button" class="arenus-product__lightbox-nav arenus-product__lightbox-nav--next" data-lightbox-next aria-label="Next image">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M9 6L15 12L9 18" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </button>
            {%- endif -%}
            <div class="arenus-product__lightbox-stage" data-lightbox-stage>
              {%- for media in product.media -%}
                <div class="arenus-product__lightbox-slide{% if forloop.first %} arenus-product__lightbox-slide--active{% endif %}" data-lightbox-slide="{{ forloop.index0 }}" data-media-type="{{ media.media_type }}">
                  {%- case media.media_type -%}
                    {%- when 'image' -%}
                      <img
                        src="{{ media | image_url: width: 1800 }}"
                        alt="{{ media.alt | escape }}"
                        loading="lazy"
                      >
                    {%- when 'video' -%}
                      <video
                        controls
                        playsinline
                        preload="none"
                        poster="{{ media.preview_image | image_url: width: 1800 }}"
                      >
                        {%- for source in media.sources -%}
                          <source src="{{ source.url }}" type="{{ source.mime_type }}">
                        {%- endfor -%}
                      </video>
                    {%- when 'external_video' -%}
                      {%- if media.host == 'youtube' -%}
                        <iframe
                          src="https://www.youtube.com/embed/{{ media.external_id }}?rel=0&playsinline=1"
                          title="{{ media.alt | escape }}"
                          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                          allowfullscreen
                          loading="lazy"
                          data-lightbox-iframe
                        ></iframe>
                      {%- elsif media.host == 'vimeo' -%}
                        <iframe
                          src="https://player.vimeo.com/video/{{ media.external_id }}?playsinline=1"
                          title="{{ media.alt | escape }}"
                          allow="autoplay; fullscreen; picture-in-picture"
                          allowfullscreen
                          loading="lazy"
                          data-lightbox-iframe
                        ></iframe>
                      {%- endif -%}
                  {%- endcase -%}
                </div>
              {%- endfor -%}
            </div>
            {%- if product.media.size > 1 -%}
              <div class="arenus-product__lightbox-counter" data-lightbox-counter aria-live="polite">
                <span data-lightbox-current>1</span> / {{ product.media.size }}
              </div>
            {%- endif -%}
          </dialog>
        {%- endif -%}
      </div>

      {%- comment -%} ── RIGHT: Info column ── {%- endcomment -%}
      <div class="arenus-product__info-col">
        {%- for block in section.blocks -%}
          {%- case block.type -%}

            {%- comment -%} ── TITLE ── {%- endcomment -%}
            {%- when 'title' -%}
              <div class="arenus-product__title-block" {{ block.shopify_attributes }}>
                {%- comment -%} Stamped star rating badge {%- endcomment -%}
                <div class="arenus-product__rating">
                  <span class="stamped-product-reviews-badge" data-id="{{ product.id }}" data-product-sku="{{ product.handle }}" data-product-type="{{ product.type }}" data-product-title="{{ product.title | escape }}" style="display:block;"></span>
                </div>

                <div class="arenus-product__title-row">
                  <h1 class="arenus-product__title">{{ product.title }}</h1>
                  <button type="button" class="arenus-product__wishlist" aria-label="Add to wishlist">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78L12 21.23l8.84-8.84a5.5 5.5 0 0 0 0-7.78z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  </button>
                </div>
              </div>

            {%- comment -%} ── PRICE ── {%- endcomment -%}
            {%- when 'price' -%}
              <div class="arenus-product__price-block" {{ block.shopify_attributes }} data-price-wrapper>
                <span class="arenus-product__price" data-product-price>{{ current_variant.price | money }}</span>
                {%- if current_variant.compare_at_price > current_variant.price -%}
                  <span class="arenus-product__price-compare" data-compare-price>{{ current_variant.compare_at_price | money }}</span>
                {%- endif -%}
              </div>

            {%- comment -%} ── SHORT DESCRIPTION ── {%- endcomment -%}
            {%- when 'short_description' -%}
              {%- if short_desc != blank -%}
                <div class="arenus-product__short-desc" {{ block.shopify_attributes }}>
                  {{ short_desc | metafield_tag }}
                </div>
              {%- endif -%}

            {%- comment -%} ── SCROLL LINKS ── {%- endcomment -%}
            {%- when 'scroll_links' -%}
              {%- liquid
                assign pdp_videos = product.metafields.custom.youtube_videos.value
                assign pdp_faqs = product.metafields.custom.faqs.value
                assign pdp_has_videos = false
                assign pdp_has_faqs = false
                if pdp_videos != blank and pdp_videos.size > 0
                  assign pdp_has_videos = true
                endif
                if pdp_faqs != blank and pdp_faqs.size > 0
                  assign pdp_has_faqs = true
                endif

                assign show_link_1 = false
                if block.settings.link_1_label != blank
                  assign show_link_1 = true
                  if block.settings.link_1_target == 'videos' and pdp_has_videos == false
                    assign show_link_1 = false
                  endif
                  if block.settings.link_1_target == 'faq' and pdp_has_faqs == false
                    assign show_link_1 = false
                  endif
                  if block.settings.link_1_target == 'faqs' and pdp_has_faqs == false
                    assign show_link_1 = false
                  endif
                endif

                assign show_link_2 = false
                if block.settings.link_2_label != blank
                  assign show_link_2 = true
                  if block.settings.link_2_target == 'videos' and pdp_has_videos == false
                    assign show_link_2 = false
                  endif
                  if block.settings.link_2_target == 'faq' and pdp_has_faqs == false
                    assign show_link_2 = false
                  endif
                  if block.settings.link_2_target == 'faqs' and pdp_has_faqs == false
                    assign show_link_2 = false
                  endif
                endif

                assign show_link_3 = false
                if block.settings.link_3_label != blank
                  assign show_link_3 = true
                  if block.settings.link_3_target == 'videos' and pdp_has_videos == false
                    assign show_link_3 = false
                  endif
                  if block.settings.link_3_target == 'faq' and pdp_has_faqs == false
                    assign show_link_3 = false
                  endif
                  if block.settings.link_3_target == 'faqs' and pdp_has_faqs == false
                    assign show_link_3 = false
                  endif
                endif
              -%}
              {% if show_link_1 or show_link_2 or show_link_3 %}
                <div class="arenus-product__scroll-links" {{ block.shopify_attributes }}>
                  {%- if show_link_1 -%}
                    <a href="#{{ block.settings.link_1_target }}" class="arenus-product__scroll-link" data-scroll-link>{{ block.settings.link_1_label }}</a>
                  {%- endif -%}
                  {%- if show_link_2 -%}
                    <a href="#{{ block.settings.link_2_target }}" class="arenus-product__scroll-link" data-scroll-link>{{ block.settings.link_2_label }}</a>
                  {%- endif -%}
                  {%- if show_link_3 -%}
                    <a href="#{{ block.settings.link_3_target }}" class="arenus-product__scroll-link" data-scroll-link>{{ block.settings.link_3_label }}</a>
                  {%- endif -%}
                </div>
              {% endif %}

            {%- comment -%} ── VARIANT SELECTOR ── {%- endcomment -%}
            {%- when 'variant_selector' -%}
              {%- unless product.has_only_default_variant -%}
                <div class="arenus-product__variants" {{ block.shopify_attributes }} data-variant-selector>
                  {%- for option in product.options_with_values -%}
                    <div class="arenus-product__option" data-option-position="{{ option.position }}">
                      <p class="arenus-product__option-label">{{ option.name }}:</p>
                      <div class="arenus-product__option-values">
                        {%- for value in option.values -%}
                          <button
                            type="button"
                            class="arenus-product__option-btn{% if option.selected_value == value %} arenus-product__option-btn--active{% endif %}"
                            data-option-position="{{ option.position }}"
                            data-option-value="{{ value | escape }}"
                          >
                            {{ value }}
                          </button>
                        {%- endfor -%}
                      </div>
                    </div>
                  {%- endfor -%}
                </div>
              {%- endunless -%}

            {%- comment -%} ── SUBSCRIPTION SELECTOR ── {%- endcomment -%}
            {%- when 'subscription_selector' -%}
              <div class="arenus-product__subscription" {{ block.shopify_attributes }}>
                {% render 'arenus-subscription-selector', product: product, selector_id: section.id %}
              </div>

            {%- comment -%} ── ADD TO CART ── {%- endcomment -%}
            {%- when 'add_to_cart' -%}
              <div class="arenus-product__buy" {{ block.shopify_attributes }}>
                {%- if block.settings.show_quantity -%}
                  <div class="arenus-product__qty" data-quantity-stepper>
                    <button type="button" class="arenus-product__qty-btn" data-qty-minus aria-label="Decrease quantity">
                      <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8H13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                    </button>
                    <input
                      type="number"
                      class="arenus-product__qty-input"
                      value="1"
                      min="1"
                      name="quantity"
                      aria-label="Quantity"
                      data-qty-input
                    >
                    <button type="button" class="arenus-product__qty-btn" data-qty-plus aria-label="Increase quantity">
                      <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M8 3V13M3 8H13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                    </button>
                  </div>
                {%- endif -%}

                <button
                  type="button"
                  class="arenus-product__atc-btn"
                  data-add-to-cart
                  {% unless current_variant.available %}disabled{% endunless %}
                >
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M20.25 6.75H3.75C3.33579 6.75 3 7.08579 3 7.5V19.5C3 19.9142 3.33579 20.25 3.75 20.25H20.25C20.6642 20.25 21 19.9142 21 19.5V7.5C21 7.08579 20.6642 6.75 20.25 6.75Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M8.25 6.75C8.25 5.75544 8.64509 4.80161 9.34835 4.09835C10.0516 3.39509 11.0054 3 12 3C12.9946 3 13.9484 3.39509 14.6517 4.09835C15.3549 4.80161 15.75 5.75544 15.75 6.75" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  <span data-atc-text>
                    {%- if current_variant.available -%}
                      ADD TO CART
                    {%- else -%}
                      SOLD OUT
                    {%- endif -%}
                  </span>
                </button>
              </div>

            {%- comment -%} ── DESCRIPTION TAB ── {%- endcomment -%}
            {%- when 'description' -%}
              {%- unless accordion_group_open -%}
                {%- assign accordion_group_open = true -%}
                <div class="arenus-product__accordions">
              {%- endunless -%}
              {% if product.description != blank %}
                <details
                  class="arenus-product__accordion"
                  id="description"
                  {{ block.shopify_attributes }}
                  {% if block.settings.open_by_default %}open{% endif %}
                >
                  <summary class="arenus-product__accordion-header">
                    <span>Description</span>
                    <span class="arenus-product__accordion-icon">
                      <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M5 7.5L10 12.5L15 7.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </span>
                  </summary>
                  <div class="arenus-product__accordion-body">
                    {{ product.description }}
                  </div>
                </details>
              {% endif %}

            {%- comment -%} ── INGREDIENTS TAB ── {%- endcomment -%}
            {%- when 'ingredients' -%}
              {%- if ingredients_meta != blank -%}
                {%- unless accordion_group_open -%}
                  {%- assign accordion_group_open = true -%}
                  <div class="arenus-product__accordions">
                {%- endunless -%}
                <details class="arenus-product__accordion" {{ block.shopify_attributes }}>
                  <summary class="arenus-product__accordion-header">
                    <span>Ingredients</span>
                    <span class="arenus-product__accordion-icon">
                      <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M5 7.5L10 12.5L15 7.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </span>
                  </summary>
                  <div class="arenus-product__accordion-body">
                    {{ ingredients_meta | metafield_tag }}
                  </div>
                </details>
              {%- endif -%}

            {%- comment -%} ── HOW TO USE TAB ── {%- endcomment -%}
            {%- when 'how_to_use' -%}
              {%- if how_to_use_meta != blank -%}
                {%- unless accordion_group_open -%}
                  {%- assign accordion_group_open = true -%}
                  <div class="arenus-product__accordions">
                {%- endunless -%}
                <details class="arenus-product__accordion" {{ block.shopify_attributes }}>
                  <summary class="arenus-product__accordion-header">
                    <span>How To Use</span>
                    <span class="arenus-product__accordion-icon">
                      <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M5 7.5L10 12.5L15 7.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </span>
                  </summary>
                  <div class="arenus-product__accordion-body">
                    {{ how_to_use_meta | metafield_tag }}
                  </div>
                </details>
              {%- endif -%}

            {%- comment -%} ── COLLAPSIBLE TAB (Shipping & Returns) ── {%- endcomment -%}
            {%- when 'collapsible_tab' -%}
              {%- unless accordion_group_open -%}
                {%- assign accordion_group_open = true -%}
                <div class="arenus-product__accordions">
              {%- endunless -%}
              <details class="arenus-product__accordion" {{ block.shopify_attributes }}>
                <summary class="arenus-product__accordion-header">
                  <span>{{ block.settings.heading | default: 'Shipping & Returns' }}</span>
                  <span class="arenus-product__accordion-icon">
                    <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M5 7.5L10 12.5L15 7.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  </span>
                </summary>
                <div class="arenus-product__accordion-body">
                  {{ block.settings.content }}
                </div>
              </details>

            {%- comment -%} ── APP BLOCK ── {%- endcomment -%}
            {%- when '@app' -%}
              {%- if accordion_group_open -%}
                {%- assign accordion_group_open = false -%}
                </div>
              {%- endif -%}
              <div class="arenus-product__app-block" {{ block.shopify_attributes }}>
                {% render block %}
              </div>

          {%- endcase -%}
        {%- endfor -%}
        {%- if accordion_group_open -%}
          </div>
        {%- endif -%}
      </div>

    </div>{%- comment -%} /.arenus-product__grid {%- endcomment -%}
  </div>{%- comment -%} /.arenus-product__inner {%- endcomment -%}

  {%- comment -%} Variant data for JS {%- endcomment -%}
  <script type="application/json" data-product-variants>
    {{ product.variants | json }}
  </script>
  <input type="hidden" name="id" value="{{ current_variant.id }}" data-variant-id>
</section>

{%- comment -%} ══════════ STYLES ══════════ {%- endcomment -%}
<style>
  /* ── Breadcrumbs ── */

  .arenus-product-breadcrumbs__inner {
    padding: 16px 20px 8px;
  }

  .arenus-product-breadcrumbs__back {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-body--family);
    font-size: 14px;
    line-height: 1.2;
    color: #000;
    text-decoration: none;
  }

  .arenus-product-breadcrumbs__trail {
    display: none;
    list-style: none;
    margin: 0;
    padding: 0;
    align-items: center;
    gap: 8px;
    font-family: var(--font-body--family);
    font-size: 14px;
