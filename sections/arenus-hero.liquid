{%- liquid
  assign has_video = false
  assign has_image = false

  if section.settings.media_type == 'video' and section.settings.video != blank
    assign has_video = true
  endif

  if section.settings.media_type == 'image' and section.settings.image != blank
    assign has_image = true
  endif

  assign fetch_priority = 'auto'
  if section.index == 1
    assign fetch_priority = 'high'
  endif
-%}

<div
  id="ArenusHero-{{ section.id }}"
  class="arenus-hero"
  style="
    --arenus-hero-bg: {{ section.settings.background_color }};
    --arenus-hero-text: {{ section.settings.text_color }};
    --arenus-hero-media-opacity: {{ section.settings.media_opacity | divided_by: 100.0 }};
    {% if section.settings.section_height == 'full-screen' %}
      --arenus-hero-min-height: 100svh;
    {% elsif section.settings.section_height == 'custom' %}
      --arenus-hero-min-height: {{ section.settings.section_height_custom }}svh;
    {% else %}
      --arenus-hero-min-height: var(--section-height-{{ section.settings.section_height }});
    {% endif %}
  "
>
  {%- comment -%} Background media {%- endcomment -%}
  <div class="arenus-hero__media">
    {%- if has_video -%}
      {{
        section.settings.video
        | video_tag:
          poster: nil,
          autoplay: true,
          loop: true,
          controls: false,
          muted: true,
          class: 'arenus-hero__video'
      }}
    {%- elsif has_image -%}
      {{
        section.settings.image
        | image_url: width: 3840
        | image_tag:
          width: section.settings.image.width,
          widths: '416, 600, 800, 1200, 1600, 1920, 2560, 3840',
          height: section.settings.image.height,
          alt: section.settings.image.alt,
          class: 'arenus-hero__image',
          sizes: '100vw',
          fetchpriority: fetch_priority
      }}
    {%- endif -%}
  </div>

  {%- comment -%} Overlay {%- endcomment -%}
  {%- if section.settings.show_overlay -%}
    {% render 'overlay', settings: section.settings %}
  {%- endif -%}

  {%- comment -%} Content {%- endcomment -%}
  <div
    class="arenus-hero__content"
    style="
      padding-block-start: {{ section.settings.padding-block-start }}px;
      padding-block-end: {{ section.settings.padding-block-end }}px;
    "
  >
    <div class="arenus-hero__text-group">
      {%- if section.settings.heading != blank -%}
        <h1 class="arenus-hero__heading">{{ section.settings.heading }}</h1>
      {%- endif -%}

      {%- if section.settings.body_text != blank -%}
        <div class="arenus-hero__body">{{ section.settings.body_text }}</div>
      {%- endif -%}
    </div>

    {%- if section.settings.button_label != blank -%}
      <a
        href="{{ section.settings.button_link | default: '#' }}"
        class="arenus-hero__button"
      >
        {{- section.settings.button_label -}}
      </a>
    {%- endif -%}
  </div>
</div>

{% stylesheet %}
  /* ===== Arenus Hero — Mobile-first ===== */

  .arenus-hero {
    position: relative;
    min-height: var(--arenus-hero-min-height, 100svh);
    background-color: var(--arenus-hero-bg, #191919);
    color: var(--arenus-hero-text, #fff);
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  /* Background media */
  .arenus-hero__media {
    position: absolute;
    inset: 0;
    opacity: var(--arenus-hero-media-opacity, 0.5);
    z-index: var(--layer-base, 0);
  }

  .arenus-hero__video,
  .arenus-hero__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center center;
  }

  /* Content */
  .arenus-hero__content {
    position: relative;
    z-index: var(--layer-flat, 1);
    margin-top: auto;
    padding-inline: 20px;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .arenus-hero__text-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .arenus-hero__heading {
    font-family: var(--font-heading--family);
    font-style: var(--font-heading--style);
    font-weight: var(--font-heading--weight);
    font-size: var(--font-size--4xl);
    line-height: var(--line-height--display-tight);
    letter-spacing: var(--letter-spacing--display-tight);
    margin: 0;
  }

  .arenus-hero__body {
    font-family: var(--font-body--family);
    font-weight: var(--font-body--weight);
    font-size: var(--font-size--sm);
    line-height: var(--line-height--body-normal);
  }

  .arenus-hero__body p {
    margin: 0;
  }

  /* CTA button — outline style */
  .arenus-hero__button {
    display: block;
    width: 100%;
    text-align: center;
    border: 1px solid currentColor;
    border-radius: 6px;
    padding: 12px 16px;
    font-family: var(--font-body--family);
    font-size: var(--font-size--sm);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: inherit;
    background: transparent;
    text-decoration: none;
    transition: background-color 0.2s ease, color 0.2s ease;
    cursor: pointer;
    -webkit-appearance: none;
  }

  .arenus-hero__button:hover {
    background-color: var(--arenus-hero-text, #fff);
    color: var(--arenus-hero-bg, #191919);
  }

  /* ===== Desktop ===== */
  @media screen and (min-width: 750px) {
    .arenus-hero {
      align-items: flex-start;
    }

    .arenus-hero__content {
      width: 584px;
      padding-inline: 40px;
      padding-block: 40px;
    }

    .arenus-hero__body {
      font-size: var(--font-size--md);
      line-height: 1.6;
      letter-spacing: -0.02em;
    }

    .arenus-hero__button {
      width: auto;
      padding: 12px 24px;
      max-width: fit-content;
    }

    .arenus-hero__heading {
      font-size: var(--font-size--6xl);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Arenus Hero",
  "tag": "section",
  "class": "arenus-hero-wrapper section-wrapper",
  "settings": [
    {
      "type": "header",
      "content": "Media"
    },
    {
      "type": "select",
      "id": "media_type",
      "label": "Media type",
      "options": [
        {
          "value": "image",
          "label": "Image"
        },
        {
          "value": "video",
          "label": "Video"
        }
      ],
      "default": "video"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image",
      "visible_if": "{{ section.settings.media_type == 'image' }}"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Video",
      "visible_if": "{{ section.settings.media_type == 'video' }}"
    },
    {
      "type": "range",
      "id": "media_opacity",
      "label": "Media opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 50
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Nutrition Engineered for Peak Wellness and Performance."
    },
    {
      "type": "richtext",
      "id": "body_text",
      "label": "Body text",
      "default": "<p>Browse our complete line of supplements and liniments. We make finding advanced solutions for Breathing, Digestion, and Soreness simple and effective.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "EXPLORE PRODUCTS"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#191919"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Overlay"
    },
    {
      "type": "checkbox",
      "id": "show_overlay",
      "label": "Show overlay",
      "default": true
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay color",
      "alpha": true,
      "default": "#00000066",
      "visible_if": "{{ section.settings.show_overlay }}"
    },
    {
      "type": "select",
      "id": "overlay_style",
      "label": "Overlay style",
      "options": [
        {
          "value": "solid",
          "label": "Solid"
        },
        {
          "value": "gradient",
          "label": "Gradient"
        }
      ],
      "default": "gradient",
      "visible_if": "{{ section.settings.show_overlay }}"
    },
    {
      "type": "select",
      "id": "gradient_direction",
      "label": "Gradient direction",
      "options": [
        {
          "value": "to top",
          "label": "Up"
        },
        {
          "value": "to bottom",
          "label": "Down"
        }
      ],
      "default": "to top",
      "visible_if": "{{ section.settings.show_overlay and section.settings.overlay_style == 'gradient' }}"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "section_height",
      "label": "Section height",
      "options": [
        {
          "value": "small",
          "label": "Small"
        },
        {
          "value": "medium",
          "label": "Medium"
        },
        {
          "value": "large",
          "label": "Large"
        },
        {
          "value": "full-screen",
          "label": "Full screen"
        },
        {
          "value": "custom",
          "label": "Custom"
        }
      ],
      "default": "full-screen"
    },
    {
      "type": "range",
      "id": "section_height_custom",
      "label": "Custom height",
      "min": 20,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 80,
      "visible_if": "{{ section.settings.section_height == 'custom' }}"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "Arenus Hero",
      "category": "Banners",
      "settings": {
        "media_type": "video",
        "media_opacity": 50,
        "heading": "Nutrition Engineered for Peak Wellness and Performance.",
        "button_label": "EXPLORE PRODUCTS",
        "background_color": "#191919",
        "text_color": "#ffffff",
        "show_overlay": true,
        "overlay_color": "#00000066",
        "overlay_style": "gradient",
        "gradient_direction": "to top",
        "section_height": "full-screen",
        "padding-block-end": 20
      }
    }
  ]
}
{% endschema %}
