{%- comment -%}
  Arenus — CAP Generic Content section
  Reusable rich-text + optional image section for CAP sub-pages
  (Overview, Wellness Programs, Terms & Conditions, etc.).
  Supports multiple content blocks (text, image, heading) in any order.
{%- endcomment -%}

<section
  id="ArenusCapContent-{{ section.id }}"
  class="arenus-cap-content c-page-width"
  style="
    padding-block-start: {{ section.settings.padding_top }}px;
    padding-block-end: {{ section.settings.padding_bottom }}px;
    --cap-content-max-width: {{ section.settings.max_width }}px;
  "
>
  {%- if section.settings.heading != blank -%}
    <h1 class="arenus-cap-content__heading">{{ section.settings.heading }}</h1>
  {%- endif -%}

  {%- assign image_layout = section.settings.image_layout | default: 'stacked' -%}

  {%- if section.blocks.size > 0 -%}
    <div class="arenus-cap-content__body arenus-cap-content__body--{{ image_layout }}">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'heading' -%}
            <h2 class="arenus-cap-content__h2" {{ block.shopify_attributes }}>{{ block.settings.text }}</h2>
          {%- when 'text' -%}
            <div class="arenus-cap-content__richtext" {{ block.shopify_attributes }}>
              {{ block.settings.content }}
            </div>
          {%- when 'image' -%}
            {%- if block.settings.image != blank -%}
              <button
                type="button"
                class="arenus-cap-content__image-wrap arenus-cap-content__image-wrap--clickable"
                data-cap-img-trigger
                data-cap-img-full="{{ block.settings.image | image_url: width: 2400 }}"
                data-cap-img-alt="{{ block.settings.alt | default: block.settings.caption | escape }}"
                data-cap-img-caption="{{ block.settings.caption | escape }}"
                aria-label="View image{% if block.settings.caption != blank %} — {{ block.settings.caption | escape }}{% endif %}"
                {{ block.shopify_attributes }}
              >
                {{
                  block.settings.image
                  | image_url: width: 1800
                  | image_tag:
                    width: block.settings.image.width,
                    height: block.settings.image.height,
                    alt: block.settings.alt,
                    loading: 'lazy',
                    class: 'arenus-cap-content__image'
                }}
                {%- if block.settings.caption != blank -%}
                  <p class="arenus-cap-content__caption">{{ block.settings.caption }}</p>
                {%- endif -%}
              </button>
            {%- endif -%}
          {%- when 'button' -%}
            {%- if block.settings.label != blank and block.settings.link != blank -%}
              <div class="arenus-cap-content__button-wrap" {{ block.shopify_attributes }}>
                <a class="arenus-cap-content__button" href="{{ block.settings.link }}">{{ block.settings.label }}</a>
              </div>
            {%- endif -%}
        {%- endcase -%}
      {%- endfor -%}
    </div>

    {%- comment -%} ───── Single-image lightbox (populated dynamically by JS) ───── {%- endcomment -%}
    <dialog class="arenus-cap-lightbox" data-cap-lightbox aria-label="Image preview">
      <button type="button" class="arenus-cap-lightbox__close" data-cap-lb-close aria-label="Close">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M6 6l12 12M18 6L6 18" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
      </button>
      <div class="arenus-cap-lightbox__stage">
        <img class="arenus-cap-lightbox__img" data-cap-lb-img alt="" />
        <p class="arenus-cap-lightbox__caption" data-cap-lb-caption hidden></p>
      </div>
    </dialog>
  {%- endif -%}
</section>

{% stylesheet %}
  .arenus-cap-content {
    margin: 0 auto;
    max-width: 1440px;
    padding-inline: 20px;
  }

  .arenus-cap-content__heading {
    font-family: var(--font-heading--family);
    font-style: var(--font-heading--style);
    font-weight: 400;
    font-size: 32px;
    line-height: 1.1;
    letter-spacing: -0.64px;
    color: #000;
    margin: 0 0 24px;
    max-width: var(--cap-content-max-width, 900px);
    margin-inline: auto;
  }

  .arenus-cap-content__body {
    max-width: var(--cap-content-max-width, 900px);
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  /* ── 3-column image layout ──
     Images flow into rows of 3 on desktop while headings, text, and buttons
     span the full width. On mobile, everything stacks. */
  .arenus-cap-content__body--3-column {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
    align-items: start;
  }

  .arenus-cap-content__body--3-column > .arenus-cap-content__h2,
  .arenus-cap-content__body--3-column > .arenus-cap-content__richtext,
  .arenus-cap-content__body--3-column > .arenus-cap-content__button-wrap {
    grid-column: 1 / -1;
  }

  .arenus-cap-content__h2 {
    font-family: var(--font-heading--family);
    font-style: var(--font-heading--style);
    font-weight: 400;
    font-size: 24px;
    line-height: 1.2;
    letter-spacing: -0.48px;
    color: #000;
    margin: 16px 0 0;
  }

  .arenus-cap-content__richtext {
    font-family: var(--font-body--family);
    font-weight: 400;
    font-size: 16px;
    line-height: 1.6;
    letter-spacing: -0.16px;
    color: #424242;
  }

  .arenus-cap-content__richtext p {
    margin: 0 0 16px;
  }

  .arenus-cap-content__richtext p:last-child {
    margin-bottom: 0;
  }

  .arenus-cap-content__richtext ul,
  .arenus-cap-content__richtext ol {
    padding-left: 20px;
    margin: 0 0 16px;
  }

  .arenus-cap-content__richtext li {
    margin-bottom: 8px;
  }

  .arenus-cap-content__richtext a {
    color: #e6b236;
    text-decoration: underline;
  }

  .arenus-cap-content__richtext strong {
    color: #000;
    font-weight: 600;
  }

  .arenus-cap-content__image-wrap {
    margin: 8px 0;
  }

  /* Reset button-default styles when image-wrap is rendered as a <button> */
  .arenus-cap-content__image-wrap--clickable {
    all: unset;
    display: block;
    cursor: zoom-in;
    width: 100%;
    border-radius: 12px;
  }

  .arenus-cap-content__image-wrap--clickable:focus-visible {
    outline: 2px solid #e6b236;
    outline-offset: 4px;
  }

  .arenus-cap-content__image {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 12px;
  }

  .arenus-cap-content__caption {
    margin: 8px 0 0;
    font-family: var(--font-body--family);
    font-size: 14px;
    line-height: 1.4;
    color: #808085;
    text-align: center;
  }

  .arenus-cap-content__button-wrap {
    margin: 8px 0;
  }

  .arenus-cap-content__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 16px 24px;
    background: #e6b236;
    color: #fff;
    border-radius: 6px;
    font-family: var(--font-body--family);
    font-weight: 500;
    font-size: 16px;
    line-height: 1;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0;
    transition: background 0.2s ease;
  }

  .arenus-cap-content__button:hover {
    background: #d9a42a;
  }

  /* ═══════════ Lightbox ═══════════ */
  .arenus-cap-lightbox {
    width: 100vw;
    height: 100vh;
    max-width: 100vw;
    max-height: 100vh;
    margin: 0;
    padding: 0;
    border: 0;
    background: rgba(0, 0, 0, 0.65);
    color: #fff;
    overflow: hidden;
  }

  .arenus-cap-lightbox::backdrop {
    background: rgba(0, 0, 0, 0.65);
  }

  .arenus-cap-lightbox[open] {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .arenus-cap-lightbox__close {
    all: unset;
    box-sizing: border-box;
    position: absolute;
    top: 24px;
    right: 24px;
    z-index: 2;
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: #fff;
    border-radius: 50%;
    background: rgba(0, 0, 0, 0.5);
    transition: background 0.2s ease;
  }

  .arenus-cap-lightbox__close:hover {
    background: rgba(0, 0, 0, 0.75);
  }

  .arenus-cap-lightbox__stage {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 16px;
    padding: 60px 16px;
    box-sizing: border-box;
  }

  .arenus-cap-lightbox__img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    border-radius: 8px;
    background: transparent;
  }

  .arenus-cap-lightbox__caption {
    margin: 0;
    font-family: var(--font-body--family);
    font-size: 14px;
    line-height: 1.4;
    color: rgba(255, 255, 255, 0.95);
    text-align: center;
  }

  @media screen and (min-width: 750px) {
    .arenus-cap-content {
      padding-inline: 40px;
    }

    .arenus-cap-content__heading {
      font-size: 48px;
      letter-spacing: -0.96px;
      margin-bottom: 40px;
    }

    .arenus-cap-content__h2 {
      font-size: 32px;
      letter-spacing: -0.64px;
    }

    .arenus-cap-content__richtext {
      font-size: 18px;
      letter-spacing: -0.18px;
    }

    .arenus-cap-content__body--3-column {
      grid-template-columns: repeat(3, 1fr);
    }

    /* Image blocks in 3-column mode keep their natural 1-col width and flow into rows of 3 */
    .arenus-cap-content__body--3-column > .arenus-cap-content__image-wrap {
      margin: 0;
    }

    .arenus-cap-lightbox__close {
      width: 48px;
      height: 48px;
    }

    .arenus-cap-lightbox__stage {
      padding: 80px;
    }
  }
{% endstylesheet %}

<script>
  (function() {
    var section = document.getElementById('ArenusCapContent-{{ section.id }}');
    if (!section) return;
    var lightbox = section.querySelector('[data-cap-lightbox]');
    if (!lightbox) return;

    var imgEl = lightbox.querySelector('[data-cap-lb-img]');
    var captionEl = lightbox.querySelector('[data-cap-lb-caption]');
    var triggers = section.querySelectorAll('[data-cap-img-trigger]');

    function open(src, alt, caption) {
      if (imgEl) {
        imgEl.src = src || '';
        imgEl.alt = alt || '';
      }
      if (captionEl) {
        if (caption) {
          captionEl.textContent = caption;
          captionEl.hidden = false;
        } else {
          captionEl.textContent = '';
          captionEl.hidden = true;
        }
      }
      if (typeof lightbox.showModal === 'function') {
        lightbox.showModal();
      } else {
        lightbox.setAttribute('open', '');
      }
      document.body.style.overflow = 'hidden';
    }

    function close() {
      if (typeof lightbox.close === 'function') {
        lightbox.close();
      } else {
        lightbox.removeAttribute('open');
      }
      document.body.style.overflow = '';
      /* Clear src so the large image isn't held in memory */
      if (imgEl) imgEl.removeAttribute('src');
    }

    triggers.forEach(function(btn) {
      btn.addEventListener('click', function() {
        open(
          btn.getAttribute('data-cap-img-full'),
          btn.getAttribute('data-cap-img-alt'),
          btn.getAttribute('data-cap-img-caption')
        );
      });
    });

    var closeBtn = lightbox.querySelector('[data-cap-lb-close]');
    if (closeBtn) closeBtn.addEventListener('click', close);

    /* Close on any click outside the image and the close button */
    lightbox.addEventListener('click', function(e) {
      if (e.target === imgEl) return;
      if (closeBtn && (e.target === closeBtn || closeBtn.contains(e.target))) return;
      close();
    });

    /* Escape / native cancel */
    lightbox.addEventListener('cancel', function(e) {
      e.preventDefault();
      close();
    });
  })();
</script>

{% schema %}
{
  "name": "CAP Content",
  "tag": "section",
  "class": "arenus-cap-content-wrapper section-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Page heading"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Content max width",
      "min": 600,
      "max": 1200,
      "step": 20,
      "unit": "px",
      "default": 900
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 56
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 56
    },
    {
      "type": "select",
      "id": "image_layout",
      "label": "Image layout",
      "options": [
        { "value": "stacked", "label": "Stacked (full width)" },
        { "value": "3-column", "label": "3-column grid (images in rows of 3)" }
      ],
      "default": "stacked",
      "info": "When 3-column is selected, consecutive image blocks lay out in rows of 3 on desktop. Headings, text, and buttons still span full width."
    }
  ],
  "blocks": [
    {
      "type": "heading",
      "name": "Heading",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Heading text",
          "default": "Section heading"
        }
      ]
    },
    {
      "type": "text",
      "name": "Rich text",
      "settings": [
        {
          "type": "richtext",
          "id": "content",
          "label": "Content",
          "default": "<p>Paragraph content goes here.</p>"
        }
      ]
    },
    {
      "type": "image",
      "name": "Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "alt",
          "label": "Alt text"
        },
        {
          "type": "text",
          "id": "caption",
          "label": "Caption"
        }
      ]
    },
    {
      "type": "button",
      "name": "Button",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Button label"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Button link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "CAP Content",
      "category": "Arenus",
      "blocks": [
        { "type": "text" }
      ]
    }
  ],
  "templates": ["page"]
}
{% endschema %}
