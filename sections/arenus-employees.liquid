{%- comment -%}
  Arenus Employees — block-based section.
  Each employee is a block with: image, name, title, bio (richtext).
{%- endcomment -%}

<div
  id="ArenusEmployees-{{ section.id }}"
  class="arenus-emp"
  style="
    --emp-bg: {{ section.settings.background_color }};
    --emp-text: {{ section.settings.text_color }};
    --emp-title-color: {{ section.settings.title_color }};
    --emp-bio-color: {{ section.settings.bio_color }};
    --emp-padding-top: {{ section.settings.padding_top }}px;
    --emp-padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="arenus-emp__inner">
    {%- if section.settings.intro_text != blank -%}
      <div class="arenus-emp__intro">{{ section.settings.intro_text }}</div>
    {%- endif -%}

    {%- for block in section.blocks -%}
      {%- case block.type -%}
        {%- when 'employee' -%}
          <div class="arenus-emp__card" {{ block.shopify_attributes }}>
            {%- if block.settings.image != blank -%}
              <div class="arenus-emp__photo">
                {{
                  block.settings.image
                  | image_url: width: 480
                  | image_tag:
                    width: block.settings.image.width,
                    widths: '118, 208, 236, 416, 480',
                    height: block.settings.image.height,
                    alt: block.settings.name,
                    class: 'arenus-emp__photo-img',
                    sizes: '(min-width: 750px) 208px, 118px',
                    loading: 'lazy'
                }}
              </div>
            {%- endif -%}

            <div class="arenus-emp__info">
              <div class="arenus-emp__name-group">
                {%- if block.settings.name != blank -%}
                  <h3 class="arenus-emp__name">{{ block.settings.name }}</h3>
                {%- endif -%}
                {%- if block.settings.title != blank -%}
                  <p class="arenus-emp__title">{{ block.settings.title }}</p>
                {%- endif -%}
              </div>

              {%- if block.settings.bio != blank -%}
                <div class="arenus-emp__bio">{{ block.settings.bio }}</div>
              {%- endif -%}
            </div>
          </div>
      {%- endcase -%}
    {%- endfor -%}
  </div>
</div>

{% stylesheet %}
  /* ===== Arenus Employees — Mobile-first ===== */

  .arenus-emp {
    background-color: var(--emp-bg, #ffffff);
    color: var(--emp-text, #000000);
    padding: var(--emp-padding-top, 40px) 20px var(--emp-padding-bottom, 72px);
  }

  .arenus-emp__inner {
    display: flex;
    flex-direction: column;
    gap: 40px;
  }

  /* Intro text */
  .arenus-emp__intro {
    font-family: var(--font-body--family);
    font-weight: var(--font-body--weight);
    font-size: 18px;
    line-height: 1.4;
    letter-spacing: -0.36px;
  }

  .arenus-emp__intro p {
    margin: 0;
  }

  /* Employee card */
  .arenus-emp__card {
    display: flex;
    flex-direction: column;
    gap: 40px;
  }

  /* Photo */
  .arenus-emp__photo {
    width: 118px;
    height: 118px;
    flex-shrink: 0;
    border-radius: 12px;
    overflow: hidden;
  }

  .arenus-emp__photo-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Info */
  .arenus-emp__info {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .arenus-emp__name-group {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .arenus-emp__name {
    font-family: var(--font-heading--family);
    font-style: var(--font-heading--style);
    font-weight: var(--font-heading--weight);
    font-size: 24px;
    line-height: 1.2;
    letter-spacing: -0.48px;
    margin: 0;
  }

  .arenus-emp__title {
    font-family: var(--font-body--family);
    font-weight: var(--font-body--weight);
    font-size: 18px;
    line-height: 1.4;
    letter-spacing: -0.36px;
    color: var(--emp-title-color, #424242);
    margin: 0;
  }

  .arenus-emp__bio {
    font-family: var(--font-body--family);
    font-weight: var(--font-body--weight);
    font-size: 14px;
    line-height: 1.5;
    letter-spacing: -0.14px;
    color: var(--emp-bio-color, #808085);
  }

  .arenus-emp__bio p {
    margin: 0;
  }

  .arenus-emp__bio a {
    color: inherit;
    text-decoration: underline;
  }

  /* ===== Desktop ===== */
  @media screen and (min-width: 750px) {
    .arenus-emp {
      padding: var(--emp-padding-top, 40px) 40px 102px;
    }
    
    .arenus-emp__intro {
      font-size: 20px;
    }

    .arenus-emp__name {
      font-size: 32px;
    }

    .arenus-emp__title {
      font-size: 20px;
    }

    .arenus-emp__inner {
      max-width: 902px;
      margin: 0 auto;
    }

    .arenus-emp__card {
      flex-direction: row;
      align-items: flex-start;
    }

    .arenus-emp__photo {
      width: 208px;
      height: 208px;
    }

    .arenus-emp__info {
      flex: 1;
      min-width: 0;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Employees",
  "tag": "section",
  "class": "arenus-emp-wrapper section-wrapper",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "richtext",
      "id": "intro_text",
      "label": "Intro text"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color (names)",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title color",
      "default": "#424242"
    },
    {
      "type": "color",
      "id": "bio_color",
      "label": "Bio color",
      "default": "#808085"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 72
    }
  ],
  "blocks": [
    {
      "type": "employee",
      "name": "Employee",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Photo"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Name",
          "default": "Employee Name"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title / Position",
          "default": "Position"
        },
        {
          "type": "richtext",
          "id": "bio",
          "label": "Bio"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Employees",
      "category": "Content",
      "settings": {
        "background_color": "#ffffff",
        "text_color": "#000000",
        "title_color": "#424242",
        "bio_color": "#808085",
        "padding_top": 40,
        "padding_bottom": 72
      }
    }
  ]
}
{% endschema %}
