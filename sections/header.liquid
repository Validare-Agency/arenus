
{% liquid
  assign search_style = 'none'

  if section.settings.show_search
    assign search_style = 'modal'
  endif

  assign transparent_handles = section.settings.transparent_pages | split: ','
  for handle in transparent_handles
    assign handle_clean = handle | strip
    if handle_clean == template.name
      assign transparent = 'always'
      assign transparent_color_scheme = section.settings.transparent_color_scheme
      break
    elsif template.name == 'page' and template.suffix == handle_clean
      assign transparent = 'always'
      assign transparent_color_scheme = section.settings.transparent_color_scheme
      break
    endif
  endfor

  if section.settings.enable_sticky_header == 'always'
    assign sticky = 'always'
  elsif section.settings.enable_sticky_header == 'scroll-up'
    assign sticky = 'scroll-up'
  endif

  if transparent and sticky
    assign transparent = 'not-sticky'
  endif

  if transparent
    if transparent_color_scheme == 'inverse'
      assign transparent_color_scheme = 'color-' | append: section.settings.color_scheme_transparent
    else
      assign transparent_color_scheme = 'color-' | append: section.settings.color_scheme_top
    endif
  endif

  capture logo
    content_for 'block', type: '_header-logo', id: 'header-logo'
  endcapture

  capture menu
    content_for 'block', type: '_header-menu', id: 'header-menu'
  endcapture

  capture mobile_menu
    content_for 'block', type: '_header-menu', id: 'header-menu', variant: 'mobile'
  endcapture

  capture navigation_bar
    content_for 'block', type: '_header-menu', id: 'header-menu', variant: 'navigation_bar', transparent: transparent
  endcapture

  capture actions
    render 'header-actions'
  endcapture

  capture search
    render 'search', style: search_style
  endcapture

  assign class = 'header'

  if transparent_color_scheme
    assign class = class | append: ' ' | append: transparent_color_scheme
  endif
%}

<script type="application/ld+json">
  {
    "@context": "http://schema.org",
    "@type": "Organization",
    "name": {{ shop.name | json }},
    {% if settings.logo %}
      "logo": {{ settings.logo | image_url: width: 500 | prepend: "https:" | json }},
    {% endif %}
    "url": {{ request.origin | append: page.url | json }}
  }
</script>

<header-component
  id="header-component"
  class="{{ class }}"
  style="
    --header-bg: {{ section.settings.header_bg_color }};
    --header-text: {{ section.settings.header_text_color }};
    --cart-badge-bg: {{ section.settings.cart_badge_color }};
    --cart-badge-text: {{ section.settings.cart_badge_text_color }};
  "
  {% if transparent %}
    transparent="{{ transparent }}"
  {% endif %}
  {% if sticky %}
    sticky="{{ sticky }}"
  {% endif %}
  data-skip-node-update
  data-scroll-direction="none"
>
  {%- if request.page_type == 'index' -%}
    <h1 class="visually-hidden">{{ shop.name }}</h1>
  {%- endif -%}

  {% render 'header-top-bar', section: section %}

  <div class="header__main-row" ref="headerRowTop">
    <div class="header__main-inner">
      <div class="header__left">
        <div class="header__logo">
          {{ logo }}
        </div>
        {% render 'header-pills', section: section %}
      </div>

      <div class="header__right">
        <div class="header__menu desktop:only">
          {{ menu }}
        </div>
        <div class="header__icons">
          {{ search }}
          {{ actions }}
          <div class="header__mobile-menu-toggle">
            {{ mobile_menu }}
          </div>
        </div>
      </div>
    </div>
  </div>

  {% if navigation_bar != blank %}
    <div class="header__row header__row--mobile desktop:hidden">
      {{ navigation_bar }}
    </div>
  {% endif %}
</header-component>

<script
  src="{{ 'header.js' | asset_url }}"
  type="module"
></script>

{%- comment -%} Scroll-based transparent header toggle {%- endcomment -%}
<script>
  (function() {
    var header = document.querySelector('header-component');
    if (!header || !header.hasAttribute('transparent')) return;

    var scrollThreshold = 10;

    function onScroll() {
      if (window.scrollY > scrollThreshold) {
        header.setAttribute('data-scrolled', '');
      } else {
        header.removeAttribute('data-scrolled');
      }
    }

    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });
  })();
</script>

{% stylesheet %}
  body {
    --header-height: 60px;
    --header-group-height: var(--header-height);
    --transparent-header-offset-boolean: 0; /* stylelint-disable-line declaration-property-value-disallowed-list */
  }

  .header {
    display: block;
  }

  /* ── Transparent header logic ── */
  .header[transparent] {
    --header-bg-color: transparent;
    --header-logo-display: none;
    --header-logo-inverse-display: block;

    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    background-color: transparent;
    z-index: var(--layer-overlay);

    &[transparent='not-sticky'][data-sticky-state='active'],
    &:has(.mega-menu__list:hover),
    &:has(.menu-list__link[aria-haspopup]:is(:hover, [aria-expanded='true'], [data-animating])),
    &:has(.menu-list__list-item[slot='overflow'] .menu-list__link:is(:hover, [aria-expanded='true'], [data-animating])) {
      --header-logo-display: unset;
      --header-logo-inverse-display: unset;
      --header-bg-color: unset;
    }
  }

  .header-section {
    position: relative;
    z-index: var(--layer-heightened);
  }

  #header-group:has(#header-component[sticky]) {
    display: contents;
  }

  .header-section:has(> #header-component[sticky='always']),
  .header-section:has(> #header-component[sticky='scroll-up'][data-sticky-state='active']) {
    position: sticky;
    top: -1px;
    z-index: var(--layer-sticky);
  }

  .header[data-sticky-state] {
    transition: opacity var(--animation-speed) var(--animation-easing);
    opacity: 1;
  }

  .header[data-sticky-state='active'] {
    view-transition-name: sticky-header;
  }

  .header[data-sticky-state='idle'],
  .header[data-sticky-state='active'][data-animating] {
    opacity: 0;
  }

  /* ── Main header row ── */
  .header__main-row {
    background-color: var(--header-bg, #191919);
    border-bottom: 1px solid #45484A;
    transition: background-color 0.3s ease, border-bottom-color 0.3s ease;
  }

  /* When header is transparent (top of page), clear main-row background */
  .header[transparent]:not([data-scrolled]):not(:has(.menu-open)) .header__main-row {
    background-color: transparent;
    border-bottom-color: transparent;
  }

  .header__main-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px 40px;
    max-width: var(--page-width);
    margin: 0 auto;
    gap: 12px;
  }

  .header__left {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .header__logo {
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }

  .header__right {
    display: flex;
    align-items: center;
    gap: 32px;
  }

  .header__menu {
    display: flex;
    align-items: center;
  }

  .header__icons {
    display: flex;
    align-items: center;
  }

  /* ── Override default theme colors for dark header ── */
  .header__main-row,
  .header__main-row * {
    /* --color-foreground: var(--header-text, #fff); */
    /* color: var(--header-text, #fff); */
  }

  .header__main-row .svg-wrapper svg,
  .header__main-row svg {
    /* color: var(--header-text, #fff); */
  }

  .header__main-row .menu-list__link {
    /* --color-foreground: var(--header-text, #fff); */
    /* color: var(--header-text, #fff) !important; */
  }

  /* Navigation link styling */
  .header__menu header-menu {
    /* --color-foreground: var(--header-text, #fff); */
  }

  .header__menu .menu-list__link {
    /* color: var(--header-text, #fff); */
    font-size: 14px;
    letter-spacing: -0.14px;
    text-decoration: none;
  }

  .header__menu .menu-list__link-title {
    color: var(--header-text, #fff);
  }
  

  /* Cart badge color override */
  .header__main-row .cart-bubble__background {
    background-color: var(--cart-badge-bg, #e6b236);
  }

  .header__main-row .cart-bubble__text {
    color: var(--cart-badge-text, #fff);
  }

  /* ── Mobile menu toggle ── */
  .header__mobile-menu-toggle {
    display: none;
  }

  @media screen and (max-width: 749px) {
    .header__mobile-menu-toggle {
      display: flex;
      align-items: center;
    }
  }

  /* ── Mobile adjustments ── */
  @media screen and (max-width: 749px) {
    .header__main-inner {
      padding: 20px;
    }

    .header__left {
      gap: 0;
    }

    .header__right {
      gap: 8px;
    }

    .header__menu {
      display: none;
    }
  }

  /* ── Plain menu list (no overflow-list) — wrap naturally ── */
  .arenus-menu-list {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 0 var(--menu-horizontal-gap, var(--gap-xl));
  }

  /* ── Transparent header offset ── */
  .header-section:has(.header[transparent]) + .shopify-section {
    margin-top: var(--header-height);
  }

  main > .shopify-section:first-child .section:not(.disable-section-top-offset) {
    &.spacing-style,
    .spacing-style {
      --section-top-offset: calc(var(--header-height) * var(--transparent-header-offset-boolean));

      :is(.spacing-style, .inherit-spacing) {
        --section-top-offset: 0px;
      }
    }

    .sticky-content {
      margin-top: calc(var(--header-height) * var(--transparent-header-offset-boolean) * -1);
    }
  }

  /* ── Submenu performance ── */
  .header-menu .menu-list__submenu {
    content-visibility: auto;
    contain-intrinsic-size: 0px 500px;
  }

  .header-menu details[open] .menu-list__submenu,
  .header-menu .menu-list__submenu[data-active] {
    content-visibility: visible;
  }

  /* ── Menu hover dimming ── */
  /* @media (hover: hover) {
    .header__menu:has(header-menu:hover) ~ .header__icons,
    .header__icons:has(.header-actions__action:hover) ~ .header__menu {
      opacity: var(--opacity-subdued-text);
      transition: opacity var(--animation-speed) var(--animation-easing);
    }
  } */

  /* Extend hover area for menu items */
  .menu-list__list-item:where(:not([slot='overflow'])) > .menu-list__link[aria-haspopup],
  .menu-list__list-item:where(:not([slot='overflow'])) > .menu-list__link,
  .menu-list__list-item:where(:not([slot='overflow'])) > button.menu-list__link {
    margin-block: calc(-2 * var(--header-padding, 20px));
    padding-block: calc(2 * var(--header-padding, 20px));
    margin-inline: calc(-1 * var(--gap-xl) / 2);
    padding-inline: calc(var(--gap-xl) / 2);
  }

  .header {
    --header-padding: 20px;
    --font-paragraph--line-height: 1;
    contain: layout style;
  }

  .header:has(#Details-menu-drawer-container[open]) {
    contain: style;
  }

  /* Desktop-only utility class */
  .desktop\:only {
    @media screen and (max-width: 749px) {
      display: none !important;
    }
  }
{% endstylesheet %}

{% unless request.design_mode %}
  <script type="module">
    import { hydrate } from '@theme/section-hydration';
    const url = new URL(window.location.href);
    url.searchParams.delete('page');
    hydrate('{{ section.id }}', url);
  </script>
{% endunless %}

