{%- comment -%}
  Arenus Dealer Cards — two-column dealer program cards with image, title,
  description, disclaimer, and CTA button. Cards are schema blocks.
{%- endcomment -%}

<div
  id="ArenusDealerCards-{{ section.id }}"
  class="arenus-dlr"
  style="
    padding-block-start: {{ section.settings.padding_top }}px;
    padding-block-end: {{ section.settings.padding_bottom }}px;
  "
>
  {%- if section.settings.heading != blank -%}
    <h2 class="arenus-dlr__heading">{{ section.settings.heading }}</h2>
  {%- endif -%}

  <div class="arenus-dlr__grid">
    {%- for block in section.blocks -%}
      <div class="arenus-dlr__card" {{ block.shopify_attributes }}>
        {%- if block.settings.image != blank -%}
          <div class="arenus-dlr__card-image">
            {{
              block.settings.image
              | image_url: width: 1200
              | image_tag:
                width: block.settings.image.width,
                widths: '353, 600, 680, 1200',
                height: block.settings.image.height,
                alt: block.settings.title,
                class: 'arenus-dlr__card-img',
                sizes: '(min-width: 750px) 680px, calc(100vw - 40px)',
                loading: 'lazy'
            }}
          </div>
        {%- endif -%}

        <div class="arenus-dlr__card-content">
          {%- if block.settings.title != blank -%}
            <h2 class="arenus-dlr__card-title">{{ block.settings.title }}</h2>
          {%- endif -%}

          {%- if block.settings.description != blank -%}
            <div class="arenus-dlr__card-body">{{ block.settings.description }}</div>
          {%- endif -%}

          {%- if block.settings.disclaimer != blank -%}
            <p class="arenus-dlr__card-disclaimer">{{ block.settings.disclaimer }}</p>
          {%- endif -%}

          {%- if block.settings.button_label != blank -%}
            <a
              href="{{ block.settings.button_link }}"
              class="arenus-dlr__card-btn"
            >
              {{ block.settings.button_label }}
            </a>
          {%- endif -%}
        </div>
      </div>
    {%- endfor -%}
  </div>
</div>

{% stylesheet %}
  /* ===== Arenus Dealer Cards — Mobile-first ===== */

  .arenus-dlr {
    padding: 40px 20px;
  }

  .arenus-dlr__heading {
    font-family: var(--font-heading--family);
    font-style: var(--font-heading--style);
    font-weight: var(--font-heading--weight);
    font-size: 32px;
    line-height: 1.1;
    letter-spacing: -0.64px;
    color: #000;
    margin: 0 0 32px;
  }

  .arenus-dlr__grid {
    display: flex;
    flex-direction: column;
    gap: 40px;
  }

  .arenus-dlr__card {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .arenus-dlr__card-image {
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: 12px;
    overflow: hidden;
    background-color: #F9F9F9;
  }

  .arenus-dlr__card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .arenus-dlr__card-content {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .arenus-dlr__card-title {
    font-family: var(--font-heading--family);
    font-style: var(--font-heading--style);
    font-weight: var(--font-heading--weight);
    font-size: 32px;
    line-height: 1.2;
    letter-spacing: -0.48px;
    color: #000;
    margin: 0;
  }

  .arenus-dlr__card-body {
    font-family: var(--font-body--family);
    font-weight: var(--font-body--weight);
    font-size: 16px;
    line-height: 1.6;
    letter-spacing: -0.32px;
    color: #424242;
  }

  .arenus-dlr__card-body p {
    margin: 0 0 0.8em;
  }

  .arenus-dlr__card-body p:last-child {
    margin-bottom: 0;
  }

  .arenus-dlr__card-disclaimer {
    font-family: var(--font-body--family);
    font-weight: var(--font-body--weight);
    font-size: 14px;
    line-height: 1.5;
    letter-spacing: -0.14px;
    color: #808085;
    font-style: italic;
    margin: 0;
  }

  .arenus-dlr__card-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 12px 24px;
    font-family: var(--font-body--family);
    font-weight: 500;
    font-size: 14px;
    line-height: 1;
    letter-spacing: 0;
    text-transform: uppercase;
    text-decoration: none;
    color: #fff;
    background-color: #E6B236;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    transition: opacity 0.2s;
    white-space: nowrap;
    box-sizing: border-box;
    align-self: flex-start;
  }

  .arenus-dlr__card-btn:hover {
    opacity: 0.85;
  }

  /* ===== Desktop ===== */
  @media screen and (min-width: 750px) {
    .arenus-dlr {
      padding: 72px 40px;
      max-width: 1440px;
      margin: 0 auto;
    }

    .arenus-dlr__heading {
      font-size: 40px;
      letter-spacing: -0.8px;
      margin-bottom: 40px;
    }

    .arenus-dlr__grid {
      flex-direction: row;
      gap: 40px;
    }

    .arenus-dlr__card {
      flex: 1 1 0;
      min-width: 0;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Dealer Cards",
  "tag": "section",
  "class": "arenus-dlr-wrapper section-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "Dealer Programs"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 72
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 72
    }
  ],
  "blocks": [
    {
      "type": "dealer_card",
      "name": "Dealer card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Card image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Dealer Program"
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "Description"
        },
        {
          "type": "text",
          "id": "disclaimer",
          "label": "Disclaimer note (optional)",
          "info": "Shown in italic grey text below the description"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label",
          "default": "APPLY NOW"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Dealer Cards",
      "category": "Content",
      "settings": {
        "heading": "Dealer Programs"
      },
      "blocks": [
        {
          "type": "dealer_card",
          "settings": {
            "title": "Sore No-More Dealer",
            "button_label": "APPLY NOW"
          }
        },
        {
          "type": "dealer_card",
          "settings": {
            "title": "Veterinary Dealer",
            "button_label": "APPLY NOW"
          }
        }
      ]
    }
  ]
}
{% endschema %}
