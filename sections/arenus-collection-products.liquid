{% endstylesheet %}

<script>
  /* ===== Arenus Collection Products — Filtering, Load More, Quick Add ===== */
  (function() {
    var section = document.getElementById('ArenusCollectionProducts-{{ section.id }}');
    if (!section) return;

    var sectionId = section.getAttribute('data-section-id');
    var collectionHandle = section.getAttribute('data-collection-handle');
    var productsPerPage = parseInt(section.getAttribute('data-products-per-page'), 10) || 20;

    var grid = section.querySelector('.arenus-cpg__grid');
    var gridWrapper = section.querySelector('.arenus-cpg__grid-wrapper');
    /* loadMoreWrap/loadMoreBtn removed — using infinite scroll instead */
    var categoryRow = section.querySelector('.arenus-cpg__filters-row--categories');
    var animalRow = section.querySelector('.arenus-cpg__filters-row--animals');
    var dialog = section.querySelector('.arenus-cpg-qam__dialog');

    var currentCategoryTag = '';
    var currentAnimalTag = '';
    var currentPage = 1;
    var totalPages = grid ? parseInt(grid.getAttribute('data-total-pages'), 10) : 1;
    var isFetching = false;

    /* --- Helpers --- */
    var rootUrl = (window.Shopify && window.Shopify.routes && window.Shopify.routes.root) || '/';
    if (rootUrl.charAt(rootUrl.length - 1) !== '/') rootUrl += '/';

    function buildCombinedTag() {
      var parts = [];
      if (currentCategoryTag) parts.push(currentCategoryTag);
      if (currentAnimalTag) parts.push(currentAnimalTag);
      return parts.join('+');
    }

    function buildUrl(tag, page) {
      var url = rootUrl + 'collections/' + collectionHandle;
      if (tag) url += '/' + tag;
      url += '?section_id=arenus-collection-products';
      if (page > 1) url += '&page=' + page;
      return url;
    }

    function extractGrid(html) {
      var tmp = document.createElement('div');
      tmp.innerHTML = html;
      var wrapper = tmp.querySelector('.arenus-cpg__grid-wrapper');
      return {
        grid: tmp.querySelector('.arenus-cpg__grid'),
        empty: tmp.querySelector('.arenus-cpg__empty'),
        sentinel: tmp.querySelector('[data-cpg-sentinel]'),
        hasActiveFilter: wrapper ? wrapper.getAttribute('data-has-active-filter') === 'true' : false
      };
    }

    function setRowLoading(row, loading) {
      if (!row) return;
      if (loading) {
        row.classList.add('is-loading');
      } else {
        row.classList.remove('is-loading');
      }
    }

    function fetchFiltered(activeRow) {
      currentPage = 1;
      isFetching = true;
      setRowLoading(activeRow, true);

      var combinedTag = buildCombinedTag();

      fetch(buildUrl(combinedTag, 1))
        .then(function(res) { return res.text(); })
        .then(function(html) {
          var extracted = extractGrid(html);

          /*
           * If we requested a tag but Shopify stripped it (redirect → no active filter),
           * show the empty state instead of the unfiltered products.
           */
          var requestedTag = combinedTag;
          var tagWasStripped = requestedTag && !extracted.hasActiveFilter;

          if (tagWasStripped) {
            /* Tag doesn't exist — show empty state */
            gridWrapper.innerHTML = '<div class="arenus-cpg__empty"><p>No products found in this category.</p></div>';
            grid = null;
            loadMoreWrap = null;
            loadMoreBtn = null;
            totalPages = 0;
            currentPage = 1;
          } else if (extracted.grid && gridWrapper) {
            gridWrapper.innerHTML = '';
            if (extracted.empty) {
              gridWrapper.appendChild(extracted.empty);
            }
            gridWrapper.appendChild(extracted.grid);
            if (extracted.sentinel) {
              gridWrapper.appendChild(extracted.sentinel);
            }

            grid = section.querySelector('.arenus-cpg__grid');
            totalPages = grid ? parseInt(grid.getAttribute('data-total-pages'), 10) : 1;
            currentPage = 1;

            setupInfiniteScroll();
            bindAddToCartButtons();
          }
          isFetching = false;
          setRowLoading(activeRow, false);
        })
        .catch(function(err) {
          console.error('Filter fetch error:', err);
          isFetching = false;
          setRowLoading(activeRow, false);
        });
    }

    /* --- Category filter click --- */
    if (categoryRow) {
      categoryRow.addEventListener('click', function(e) {
        var btn = e.target.closest('.arenus-cpg__filter-btn');
        if (!btn || isFetching) return;

        var tag = btn.getAttribute('data-tag') || '';
        if (tag === currentCategoryTag) return;

        /* Update active state within this row only */
        categoryRow.querySelectorAll('.arenus-cpg__filter-btn').forEach(function(b) { b.classList.remove('is-active'); });
        btn.classList.add('is-active');

        currentCategoryTag = tag;
        fetchFiltered(categoryRow);
      });
    }

    /* --- Animal filter click --- */
    if (animalRow) {
      animalRow.addEventListener('click', function(e) {
        var btn = e.target.closest('.arenus-cpg__filter-btn');
        if (!btn || isFetching) return;

        var tag = btn.getAttribute('data-tag') || '';

        /* Toggle: clicking the already-active animal deselects it */
        if (tag === currentAnimalTag) {
          btn.classList.remove('is-active');
          currentAnimalTag = '';
        } else {
          animalRow.querySelectorAll('.arenus-cpg__filter-btn').forEach(function(b) { b.classList.remove('is-active'); });
          btn.classList.add('is-active');
          currentAnimalTag = tag;
        }

        fetchFiltered(animalRow);
      });
    }

    /* --- Infinite Scroll --- */
    var infiniteObserver = null;

    function setupInfiniteScroll() {
      if (infiniteObserver) infiniteObserver.disconnect();
      var sentinel = section.querySelector('[data-cpg-sentinel]');
      if (!sentinel || currentPage >= totalPages) {
        if (sentinel) sentinel.remove();
        return;
      }

      infiniteObserver = new IntersectionObserver(function(entries) {
        if (entries[0].isIntersecting && !isFetching && currentPage < totalPages) {
          loadNextPage();
        }
      }, { rootMargin: '200px' });

      infiniteObserver.observe(sentinel);
    }

    function loadNextPage() {
      if (isFetching || currentPage >= totalPages) return;
      isFetching = true;

      var nextPage = currentPage + 1;
      var spinner = section.querySelector('[data-cpg-spinner]');
      if (spinner) spinner.hidden = false;

      fetch(buildUrl(buildCombinedTag(), nextPage))
        .then(function(res) { return res.text(); })
        .then(function(html) {
          var extracted = extractGrid(html);
          if (extracted.grid && grid) {
            var newCards = extracted.grid.querySelectorAll('.arenus-cpg__card');
            newCards.forEach(function(card) {
              grid.appendChild(card);
            });

            currentPage = nextPage;

            var newTotalPages = parseInt(extracted.grid.getAttribute('data-total-pages'), 10);
            if (newTotalPages) totalPages = newTotalPages;

            bindAddToCartButtons();
          }

          if (spinner) spinner.hidden = true;
          isFetching = false;

          if (currentPage >= totalPages) {
            if (infiniteObserver) infiniteObserver.disconnect();
            var sentinel = section.querySelector('[data-cpg-sentinel]');
            if (sentinel) sentinel.remove();
          }
        })
        .catch(function(err) {
          console.error('Infinite scroll fetch error:', err);
          if (spinner) spinner.hidden = true;
          isFetching = false;
        });
    }

    setupInfiniteScroll();

    /* ===== Quick Add-to-Cart (modal) ===== */
    if (!dialog) return;

    var currentProductData = null;
    var currentSubInstance = null;
    var selectedOptions = [];
    var quantity = 1;
    var isAdding = false;

    var modalTitle = dialog.querySelector('.arenus-cpg-qam__title');
    var modalPrice = dialog.querySelector('.arenus-cpg-qam__price');
    var modalComparePrice = dialog.querySelector('.arenus-cpg-qam__compare-price');
    var modalImage = dialog.querySelector('.arenus-cpg-qam__image img');
    var modalOptions = dialog.querySelector('.arenus-cpg-qam__options');
    var modalAddBtn = dialog.querySelector('.arenus-cpg-qam__add-btn');
    var modalCloseBtn = dialog.querySelector('.arenus-cpg-qam__close');
    var stepperValue = dialog.querySelector('.arenus-cpg-qam__stepper-value');
    var stepperMinus = dialog.querySelector('.arenus-cpg-qam__stepper-minus');
    var stepperPlus = dialog.querySelector('.arenus-cpg-qam__stepper-plus');

    function formatPrice(cents) {
      return '$' + (cents / 100).toFixed(2);
    }

    function findVariant() {
      if (!currentProductData) return null;
      for (var i = 0; i < currentProductData.variants.length; i++) {
        var v = currentProductData.variants[i];
        var match = true;
        for (var j = 0; j < selectedOptions.length; j++) {
          if (v.options[j] !== selectedOptions[j]) { match = false; break; }
        }
        if (match) return v;
      }
      return null;
    }

    function isOptionAvailable(optionIndex, optionValue) {
      if (!currentProductData) return false;
      for (var i = 0; i < currentProductData.variants.length; i++) {
        var v = currentProductData.variants[i];
        if (v.options[optionIndex] !== optionValue) continue;
        var compatible = true;
        for (var j = 0; j < selectedOptions.length; j++) {
          if (j === optionIndex) continue;
          if (v.options[j] !== selectedOptions[j]) { compatible = false; break; }
        }
        if (compatible && v.available) return true;
      }
      return false;
    }

    function buildModalOptions() {
      if (!currentProductData || !modalOptions) return;
      modalOptions.innerHTML = '';
      var options = currentProductData.options;
      for (var i = 0; i < options.length; i++) {
        var opt = options[i];
        var group = document.createElement('div');
        group.className = 'arenus-cpg-qam__option-group';

        var label = document.createElement('p');
        label.className = 'arenus-cpg-qam__option-label';
        label.textContent = opt.name + ':';
        group.appendChild(label);

        var valuesWrap = document.createElement('div');
        valuesWrap.className = 'arenus-cpg-qam__option-values';

        for (var j = 0; j < opt.values.length; j++) {
          var val = opt.values[j];
          var btn = document.createElement('button');
          btn.type = 'button';
          btn.className = 'arenus-cpg-qam__option-btn';
          btn.textContent = val;
          btn.setAttribute('data-option-index', i);
          btn.setAttribute('data-option-value', val);
          if (selectedOptions[i] === val) btn.classList.add('is-selected');
          if (!isOptionAvailable(i, val)) btn.classList.add('is-unavailable');
          valuesWrap.appendChild(btn);
        }

        group.appendChild(valuesWrap);
        modalOptions.appendChild(group);
      }
    }

    function updateModalPrices(variant) {
      if (modalPrice) {
        modalPrice.textContent = variant ? formatPrice(variant.price) : '';
      }
      if (modalComparePrice) {
        var hasCompare = variant && variant.compare_at_price && variant.compare_at_price > variant.price;
        modalComparePrice.textContent = hasCompare ? formatPrice(variant.compare_at_price) : '';
      }
    }

    function updateModalState() {
      var variant = findVariant();
      buildModalOptions();
      updateModalPrices(variant);
      if (modalAddBtn) {
        modalAddBtn.disabled = !variant || !variant.available;
      }
      if (currentSubInstance && variant) {
        currentSubInstance.setVariant(variant.id);
      }
    }

    if (modalOptions) {
      modalOptions.addEventListener('click', function(e) {
        var btn = e.target.closest('.arenus-cpg-qam__option-btn');
        if (!btn) return;
        var idx = parseInt(btn.getAttribute('data-option-index'), 10);
        var val = btn.getAttribute('data-option-value');
        selectedOptions[idx] = val;
        updateModalState();
      });
    }

    if (stepperMinus) {
      stepperMinus.addEventListener('click', function() {
        if (quantity > 1) { quantity--; stepperValue.textContent = quantity; }
      });
    }

    if (stepperPlus) {
      stepperPlus.addEventListener('click', function() {
        quantity++;
        stepperValue.textContent = quantity;
      });
    }

    function openModal(productData) {
      currentProductData = productData;
      quantity = 1;
      selectedOptions = [];
      for (var i = 0; i < productData.options.length; i++) {
        selectedOptions.push(productData.options[i].values[0]);
      }
      if (modalTitle) modalTitle.textContent = productData.title;
      if (modalImage) { modalImage.src = productData.image; modalImage.alt = productData.title; }
      if (stepperValue) stepperValue.textContent = '1';
      /* Update Stamped badge in modal */
      var modalBadge = dialog.querySelector('.arenus-cpg-qam__stamped-badge');
      if (modalBadge) {
        modalBadge.setAttribute('data-id', productData.id);
        modalBadge.setAttribute('data-product-sku', productData.handle || '');
        modalBadge.setAttribute('data-product-title', productData.title || '');
        modalBadge.innerHTML = '';
        if (typeof StampedFn !== 'undefined' && StampedFn.loadBadges) { StampedFn.loadBadges(); }
      }
      buildModalOptions();
      var variant = findVariant();
      updateModalPrices(variant);
      /* Render subscription selector */
      try {
        var subWrap = dialog.querySelector('[data-sub-wrap]');
        if (subWrap && window.ArenusSubscription) {
          currentSubInstance = window.ArenusSubscription.render(subWrap, productData, {
            variantId: variant ? variant.id : productData.variants[0].id
          });
        }
      } catch (err) {
        console.error('Subscription render failed:', err);
      }
      if (modalAddBtn) modalAddBtn.disabled = !variant || !variant.available;
      dialog.classList.remove('is-closing');
      dialog.showModal();
      var scrollY = window.scrollY;
      dialog._previousScrollY = scrollY;
      document.body.style.width = '100%';
      document.body.style.position = 'fixed';
      document.body.style.top = '-' + scrollY + 'px';
    }

    function closeModal() {
      dialog.classList.add('is-closing');
      function onEnd() {
        dialog.removeEventListener('animationend', onEnd);
        dialog.close();
        dialog.classList.remove('is-closing');
        document.body.style.width = '';
        document.body.style.position = '';
        document.body.style.top = '';
        if (dialog._previousScrollY !== undefined) {
          window.scrollTo({ top: dialog._previousScrollY, behavior: 'instant' });
        }
        if (currentSubInstance) { currentSubInstance.destroy(); currentSubInstance = null; }
        currentProductData = null;
        selectedOptions = [];
        quantity = 1;
      }
      dialog.addEventListener('animationend', onEnd);
    }

    if (modalCloseBtn) {
      modalCloseBtn.addEventListener('click', function() { closeModal(); });
    }

    dialog.addEventListener('click', function(e) {
      if (e.target === dialog) closeModal();
    });

    dialog.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') { e.preventDefault(); closeModal(); }
    });

    dialog.addEventListener('cancel', function(e) {
      e.preventDefault();
      closeModal();
    });

    function setButtonLoading(btn, loading) {
      if (!btn) return;
      if (loading) {
        btn._prevHTML = btn.innerHTML;
        btn.classList.add('is-loading');
        btn.innerHTML = `
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <path d="M22.4893 18.5737L21.1525 7.32375C21.1091 6.95721 20.9321 6.61952 20.6554 6.37529C20.3786 6.13106 20.0215 5.99744 19.6525 6H16.4996C16.4996 4.80653 16.0255 3.66193 15.1816 2.81802C14.3377 1.97411 13.1931 1.5 11.9996 1.5C10.8062 1.5 9.66157 1.97411 8.81766 2.81802C7.97374 3.66193 7.49964 4.80653 7.49964 6H4.34308C3.97399 5.99744 3.61691 6.13106 3.34016 6.37529C3.06342 6.61952 2.88644 6.95721 2.84308 7.32375L1.5062 18.5737C1.4817 18.7837 1.50186 18.9965 1.56536 19.1981C1.62885 19.3998 1.73425 19.5857 1.87464 19.7438C2.01604 19.9025 2.18932 20.0296 2.38317 20.1168C2.57701 20.204 2.78707 20.2494 2.99964 20.25H20.9921C21.206 20.2505 21.4175 20.2056 21.6127 20.1183C21.8079 20.0311 21.9824 19.9034 22.1246 19.7438C22.2644 19.5854 22.3691 19.3993 22.4319 19.1977C22.4948 18.9961 22.5143 18.7835 22.4893 18.5737ZM11.9996 3C12.7953 3 13.5584 3.31607 14.121 3.87868C14.6836 4.44129 14.9996 5.20435 14.9996 6H8.99964C8.99964 5.20435 9.31571 4.44129 9.87832 3.87868C10.4409 3.31607 11.204 3 11.9996 3ZM2.99964 18.75L4.34308 7.5H7.49964V9.75C7.49964 9.94891 7.57866 10.1397 7.71931 10.2803C7.85996 10.421 8.05073 10.5 8.24964 10.5C8.44855 10.5 8.63932 10.421 8.77997 10.2803C8.92062 10.1397 8.99964 9.94891 8.99964 9.75V7.5H14.9996V9.75C14.9996 9.94891 15.0787 10.1397 15.2193 10.2803C15.36 10.421 15.5507 10.5 15.7496 10.5C15.9486 10.5 16.1393 10.421 16.28 10.2803C16.4206 10.1397 16.4996 9.94891 16.4996 9.75V7.5H19.6637L20.9921 18.75H2.99964Z" fill="currentColor"/>
                </svg>
                ADDING...`;
      } else {
        btn.classList.remove('is-loading');
        if (btn._prevHTML !== undefined) btn.innerHTML = btn._prevHTML;
      }
    }

    function addToCart(variantId, qty, triggerBtn, onDone, sellingPlanId) {
      if (isAdding) return;
      isAdding = true;
      setButtonLoading(triggerBtn, true);
      var body = { id: variantId, quantity: qty };
      if (sellingPlanId) body.selling_plan = parseInt(sellingPlanId, 10);
      fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify(body)
      })
      .then(function(res) { return res.json(); })
      .then(function(data) {
        if (data.status) {
          console.error('Add to cart error:', data.description);
          isAdding = false;
          setButtonLoading(triggerBtn, false);
          return;
        }
        document.dispatchEvent(new CustomEvent('cart:update', {
          bubbles: true,
          detail: { resource: {}, sourceId: '', data: { source: 'arenus-quick-add', itemCount: qty } }
        }));
        var cartDrawer = document.querySelector('cart-drawer-component');
        if (cartDrawer) {
          if (typeof cartDrawer.open === 'function') cartDrawer.open();
          else if (typeof cartDrawer.showDialog === 'function') cartDrawer.showDialog();
        }
        isAdding = false;
        setButtonLoading(triggerBtn, false);
        if (typeof onDone === 'function') onDone();
      })
      .catch(function(err) {
        console.error('Add to cart fetch error:', err);
        isAdding = false;
        setButtonLoading(triggerBtn, false);
      });
    }

    if (modalAddBtn) {
      modalAddBtn.addEventListener('click', function() {
        var variant = findVariant();
        if (!variant || !variant.available) return;
        var sellingPlanId = currentSubInstance ? currentSubInstance.getSellingPlanId() : null;
        addToCart(variant.id, quantity, modalAddBtn, function() { closeModal(); }, sellingPlanId);
      });
    }

    /* --- Card add-to-cart button handlers (delegated to grid wrapper for AJAX support) --- */
    function bindAddToCartButtons() {
      /* Use event delegation on the grid wrapper so newly loaded cards work */
    }

    /* Delegated click handler on grid wrapper */
    if (gridWrapper) {
      gridWrapper.addEventListener('click', function(e) {
        var btn = e.target.closest('.arenus-cpg__add-btn');
        if (!btn) return;
        e.preventDefault();
        e.stopPropagation();

        var isSingleVariant = btn.hasAttribute('data-single-variant');
        if (isSingleVariant) {
          var variantId = parseInt(btn.getAttribute('data-variant-id'), 10);
          addToCart(variantId, 1, btn);
        } else {
          var card = btn.closest('.arenus-cpg__card');
          if (!card) return;
          var scriptTag = card.querySelector('.arenus-cpg__card-data');
          if (!scriptTag) return;
          try {
            var productData = JSON.parse(scriptTag.textContent);
            openModal(productData);
          } catch (err) {
            console.error('Failed to parse product data:', err);
          }
        }
      });
    }
  })();
</script>

