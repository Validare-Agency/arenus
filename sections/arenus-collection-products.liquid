{%- comment -%}
  Arenus Collection Products — Grid with tag filtering, quick-add-to-cart, and AJAX "Load More"
{%- endcomment -%}

{%- liquid
  assign products_per_page = section.settings.products_per_page
  assign image_bg = settings.product_card_image_bg
-%}

<div
  id="ArenusCollectionProducts-{{ section.id }}"
  class="arenus-cpg"
  data-section-id="{{ section.id }}"
  data-collection-handle="{{ collection.handle }}"
  data-products-per-page="{{ products_per_page }}"
  style="
    --arenus-cpg-image-bg: {{ image_bg }};
    padding-block-start: {{ section.settings.padding_top }}px;
    padding-block-end: {{ section.settings.padding_bottom }}px;
  "
>
  {%- comment -%} ── Filter buttons ── {%- endcomment -%}
  {%- if section.blocks.size > 0 -%}
    <div class="arenus-cpg__filters">
      <div class="arenus-cpg__filters-row arenus-cpg__filters-row--categories">
        {%- for block in section.blocks -%}
          {%- if block.type == 'filter' -%}
            <button
              type="button"
              class="arenus-cpg__filter-btn{% if forloop.first %} is-active{% endif %}"
              data-tag="{{ block.settings.tag | handleize }}"
              {{ block.shopify_attributes }}
            >
              {{ block.settings.label }}
            </button>
          {%- endif -%}
        {%- endfor -%}
      </div>
      {%- comment -%} Animal filter row (separate row on mobile, same row on desktop) {%- endcomment -%}
      {%- assign has_animal_filters = false -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'animal_filter' -%}
          {%- assign has_animal_filters = true -%}
          {%- break -%}
        {%- endif -%}
      {%- endfor -%}
      {%- if has_animal_filters -%}
        <div class="arenus-cpg__filters-row arenus-cpg__filters-row--animals">
          {%- for block in section.blocks -%}
            {%- if block.type == 'animal_filter' -%}
              <button
                type="button"
                class="arenus-cpg__filter-btn arenus-cpg__filter-btn--animal"
                data-tag="{{ block.settings.tag | handleize }}"
                {{ block.shopify_attributes }}
              >
                {%- if block.settings.icon == 'horse' -%}
                  {{ 'icon-horse.svg' | inline_asset_content }}
                  {% comment %} <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <path d="M14.5 1.5L13.5 2.5C13.5 2.5 12.5 2.5 11.5 3.5C10.5 4.5 10.5 6.5 10.5 6.5L8.5 8.5C8.5 8.5 7.5 7.5 6 7.5C4.5 7.5 3 8.5 2 10C1 11.5 1 13 1 14.5H3C3 14.5 3 13 3.5 12C4 11 5 10 6 10C7 10 7.5 10.5 7.5 10.5L5.5 14.5H7.5L9.5 10.5C9.5 10.5 11 9 12 8L14.5 5.5V1.5Z" fill="currentColor"/>
                  </svg> {% endcomment %}
                {%- elsif block.settings.icon == 'dog' -%}
                  {{ 'icon-dog.svg' | inline_asset_content }}
                  {% comment %} <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <path d="M13.5 3.5L14.5 1.5H12.5L11 3C11 3 9.5 2.5 8 2.5C6.5 2.5 5 3 5 3L3.5 1.5H1.5L2.5 3.5C2.5 3.5 1 5 1 7C1 9 2 10 2 10V14.5H4V11C4 11 5.5 12 8 12C10.5 12 12 11 12 11V14.5H14V10C14 10 15 9 15 7C15 5 13.5 3.5 13.5 3.5ZM5 8C4.44772 8 4 7.55228 4 7C4 6.44772 4.44772 6 5 6C5.55228 6 6 6.44772 6 7C6 7.55228 5.55228 8 5 8Z" fill="currentColor"/>
                  </svg> {% endcomment %}
                {%- endif -%}
                {{ block.settings.label }}
              </button>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>
  {%- endif -%}

  {%- comment -%} ── Products grid ── {%- endcomment -%}
  {%- comment -%}
    Detect whether the current tag filter is valid:
    current_tags is set by Shopify when the URL includes /tag-handle.
    If Shopify redirects (tag doesn't exist anywhere), current_tags is empty.
    We also track the requested tag via query param so JS can compare.
  {%- endcomment -%}
  {%- assign has_active_filter = false -%}
  {%- if current_tags and current_tags.size > 0 -%}
    {%- assign has_active_filter = true -%}
  {%- endif -%}
  <div class="arenus-cpg__grid-wrapper" data-has-active-filter="{{ has_active_filter }}" data-current-tags="{{ current_tags | join: '+' | handleize }}">
    {% paginate collection.products by products_per_page %}
      {%- if collection.products_count == 0 and has_active_filter -%}
        <div class="arenus-cpg__empty">
          <p>No products found in this category.</p>
        </div>
      {%- endif -%}
      <div class="arenus-cpg__grid" data-page="{{ paginate.current_page }}" data-total-pages="{{ paginate.pages }}" {% if collection.products_count == 0 and has_active_filter %}style="display:none"{% endif %}>
        {%- for product in collection.products -%}
          <div class="arenus-cpg__card">
            <a href="{{ product.url }}" class="arenus-cpg__card-link" aria-label="{{ product.title | escape }}" tabindex="-1"></a>
            <div class="arenus-cpg__card-image">
              {%- if product.featured_image != blank -%}
                {{ product.featured_image | image_url: width: 800 | image_tag: loading: 'lazy', widths: '200, 400, 600, 800' }}
              {%- endif -%}
            </div>

            {%- comment -%} Product info {%- endcomment -%}
            <div class="arenus-cpg__card-info">
              {%- comment -%} Stamped star rating badge {%- endcomment -%}
              <div class="arenus-cpg__rating">
                <span class="stamped-product-reviews-badge" data-id="{{ product.id }}" data-product-sku="{{ product.handle }}" data-product-type="{{ product.type }}" data-product-title="{{ product.title | escape }}" style="display:block;"></span>
              </div>

              {%- comment -%} Title + price {%- endcomment -%}
              <div class="arenus-cpg__title-price">
                <span class="arenus-cpg__title">{{ product.title }}</span>
                <span class="arenus-cpg__price">
                  {%- render 'format-price', price: product.selected_or_first_available_variant.price -%}
                </span>
              </div>

              {%- comment -%} Tag badges {%- endcomment -%}
              {%- assign badges = product.metafields.custom.product_card_badges.value -%}
              {%- if badges != blank and badges.size > 0 -%}
                <div class="arenus-cpg__tags">
                  {%- for badge in badges -%}
                    <span class="arenus-cpg__tag">{{ badge }}</span>
                  {%- endfor -%}
                </div>
              {%- endif -%}
            </div>

            {%- comment -%} Quick add-to-cart button {%- endcomment -%}
            <button
              type="button"
              class="arenus-cpg__add-btn{% unless product.available %} is-sold-out{% endunless %}"
              data-product-id="{{ product.id }}"
              data-variant-id="{{ product.selected_or_first_available_variant.id }}"
              {% if product.has_only_default_variant %}
                data-single-variant="true"
              {% endif %}
              {% unless product.available %}disabled{% endunless %}
              aria-label="{% if product.available %}Add {{ product.title | escape }} to cart{% else %}{{ product.title | escape }} is sold out{% endif %}"
            >
              {%- if product.available -%}
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <path d="M22.4893 18.5737L21.1525 7.32375C21.1091 6.95721 20.9321 6.61952 20.6554 6.37529C20.3786 6.13106 20.0215 5.99744 19.6525 6H16.4996C16.4996 4.80653 16.0255 3.66193 15.1816 2.81802C14.3377 1.97411 13.1931 1.5 11.9996 1.5C10.8062 1.5 9.66157 1.97411 8.81766 2.81802C7.97374 3.66193 7.49964 4.80653 7.49964 6H4.34308C3.97399 5.99744 3.61691 6.13106 3.34016 6.37529C3.06342 6.61952 2.88644 6.95721 2.84308 7.32375L1.5062 18.5737C1.4817 18.7837 1.50186 18.9965 1.56536 19.1981C1.62885 19.3998 1.73425 19.5857 1.87464 19.7438C2.01604 19.9025 2.18932 20.0296 2.38317 20.1168C2.57701 20.204 2.78707 20.2494 2.99964 20.25H20.9921C21.206 20.2505 21.4175 20.2056 21.6127 20.1183C21.8079 20.0311 21.9824 19.9034 22.1246 19.7438C22.2644 19.5854 22.3691 19.3993 22.4319 19.1977C22.4948 18.9961 22.5143 18.7835 22.4893 18.5737ZM11.9996 3C12.7953 3 13.5584 3.31607 14.121 3.87868C14.6836 4.44129 14.9996 5.20435 14.9996 6H8.99964C8.99964 5.20435 9.31571 4.44129 9.87832 3.87868C10.4409 3.31607 11.204 3 11.9996 3ZM2.99964 18.75L4.34308 7.5H7.49964V9.75C7.49964 9.94891 7.57866 10.1397 7.71931 10.2803C7.85996 10.421 8.05073 10.5 8.24964 10.5C8.44855 10.5 8.63932 10.421 8.77997 10.2803C8.92062 10.1397 8.99964 9.94891 8.99964 9.75V7.5H14.9996V9.75C14.9996 9.94891 15.0787 10.1397 15.2193 10.2803C15.36 10.421 15.5507 10.5 15.7496 10.5C15.9486 10.5 16.1393 10.421 16.28 10.2803C16.4206 10.1397 16.4996 9.94891 16.4996 9.75V7.5H19.6637L20.9921 18.75H2.99964Z" fill="currentColor"/>
                </svg>
                ADD TO CART
              {%- else -%}
                SOLD OUT
              {%- endif -%}
            </button>

            {%- comment -%} Variant data for quick-add modal {%- endcomment -%}
            {%- unless product.has_only_default_variant -%}
              {%- assign sp_group = product.selling_plan_groups | first -%}
              <script type="application/json" class="arenus-cpg__card-data">
                {
                  "id": {{ product.id }},
                  "handle": {{ product.handle | json }},
                  "title": {{ product.title | json }},
                  "url": {{ product.url | json }},
                  "image": {{ product.featured_image | image_url: width: 400 | json }},
                  "options": {{ product.options_with_values | json }},
                  {%- if sp_group and sp_group.selling_plans.size > 0 -%}
                  "selling_plan_group": {
                    "id": {{ sp_group.id | json }},
                    "plans": [
                      {%- for plan in sp_group.selling_plans -%}
                        { "id": {{ plan.id }}, "name": {{ plan.name | json }} }{% unless forloop.last %},{% endunless %}
                      {%- endfor -%}
                    ]
                  },
                  {%- endif -%}
                  "variants": [
                    {%- for variant in product.variants -%}
                      {
                        "id": {{ variant.id }},
                        "available": {{ variant.available }},
                        "price": {{ variant.price }},
                        "compare_at_price": {{ variant.compare_at_price | default: 0 }},
                        "options": {{ variant.options | json }},
                        "selling_plan_allocations": [
                          {%- for alloc in variant.selling_plan_allocations -%}
                            { "selling_plan_id": {{ alloc.selling_plan_id }}, "price": {{ alloc.price }} }{% unless forloop.last %},{% endunless %}
                          {%- endfor -%}
                        ]
                      }{%- unless forloop.last -%},{%- endunless -%}
                    {%- endfor -%}
                  ]
                }
              </script>
            {%- endunless -%}
          </div>
        {%- endfor -%}
      </div>

      {%- comment -%} Infinite scroll sentinel {%- endcomment -%}
      {%- if paginate.pages > 1 -%}
        <div class="arenus-cpg__sentinel" data-cpg-sentinel>
          <div class="arenus-cpg__spinner" data-cpg-spinner hidden>
            <svg width="24" height="24" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <circle cx="12" cy="12" r="10" stroke="#ddd" stroke-width="3" fill="none" />
              <path d="M12 2a10 10 0 0 1 10 10" stroke="#E6B236" stroke-width="3" fill="none" stroke-linecap="round">
                <animateTransform attributeName="transform" type="rotate" from="0 12 12" to="360 12 12" dur="0.8s" repeatCount="indefinite"/>
              </path>
            </svg>
          </div>
        </div>
      {%- endif -%}
    {% endpaginate %}
  </div>

  {%- comment -%} Quick-add modal (shared, single instance) {%- endcomment -%}
  <dialog class="arenus-cpg-qam__dialog" id="arenus-cpg-qam-{{ section.id }}">
    <div class="arenus-cpg-qam">
      <button type="button" class="arenus-cpg-qam__close" aria-label="Close">
        {{ 'icon-close-black.svg' | inline_asset_content }}
      </button>

      <div class="arenus-cpg-qam__header">
        <div class="arenus-cpg-qam__image">
          <img src="" alt="" width="80" height="80" loading="lazy" />
        </div>
        <div class="arenus-cpg-qam__meta">
          <div class="arenus-cpg-qam__rating">
            <span class="stamped-product-reviews-badge arenus-cpg-qam__stamped-badge" style="display:block;"></span>
          </div>
          <h3 class="arenus-cpg-qam__title"></h3>
          <div class="arenus-cpg-qam__price-wrap">
            <span class="arenus-cpg-qam__price"></span>
            <span class="arenus-cpg-qam__compare-price"></span>
          </div>
        </div>
      </div>

      <div class="arenus-cpg-qam__options"></div>

      <div class="arenus-cpg-qam__subscription" data-sub-wrap></div>

      <div class="arenus-cpg-qam__footer">
        <div class="arenus-cpg-qam__stepper">
          <button type="button" class="arenus-cpg-qam__stepper-btn arenus-cpg-qam__stepper-minus" aria-label="Decrease quantity">
            <svg width="16" height="16" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M2.75 7H11.25" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </button>
          <span class="arenus-cpg-qam__stepper-value">1</span>
          <button type="button" class="arenus-cpg-qam__stepper-btn arenus-cpg-qam__stepper-plus" aria-label="Increase quantity">
            <svg width="16" height="16" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M2.75 7H11.25" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              <path d="M7 2.75L7 11.25" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </button>
        </div>
        <button type="button" class="arenus-cpg-qam__add-btn" disabled>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M22.4893 18.5737L21.1525 7.32375C21.1091 6.95721 20.9321 6.61952 20.6554 6.37529C20.3786 6.13106 20.0215 5.99744 19.6525 6H16.4996C16.4996 4.80653 16.0255 3.66193 15.1816 2.81802C14.3377 1.97411 13.1931 1.5 11.9996 1.5C10.8062 1.5 9.66157 1.97411 8.81766 2.81802C7.97374 3.66193 7.49964 4.80653 7.49964 6H4.34308C3.97399 5.99744 3.61691 6.13106 3.34016 6.37529C3.06342 6.61952 2.88644 6.95721 2.84308 7.32375L1.5062 18.5737C1.4817 18.7837 1.50186 18.9965 1.56536 19.1981C1.62885 19.3998 1.73425 19.5857 1.87464 19.7438C2.01604 19.9025 2.18932 20.0296 2.38317 20.1168C2.57701 20.204 2.78707 20.2494 2.99964 20.25H20.9921C21.206 20.2505 21.4175 20.2056 21.6127 20.1183C21.8079 20.0311 21.9824 19.9034 22.1246 19.7438C22.2644 19.5854 22.3691 19.3993 22.4319 19.1977C22.4948 18.9961 22.5143 18.7835 22.4893 18.5737ZM11.9996 3C12.7953 3 13.5584 3.31607 14.121 3.87868C14.6836 4.44129 14.9996 5.20435 14.9996 6H8.99964C8.99964 5.20435 9.31571 4.44129 9.87832 3.87868C10.4409 3.31607 11.204 3 11.9996 3ZM2.99964 18.75L4.34308 7.5H7.49964V9.75C7.49964 9.94891 7.57866 10.1397 7.71931 10.2803C7.85996 10.421 8.05073 10.5 8.24964 10.5C8.44855 10.5 8.63932 10.421 8.77997 10.2803C8.92062 10.1397 8.99964 9.94891 8.99964 9.75V7.5H14.9996V9.75C14.9996 9.94891 15.0787 10.1397 15.2193 10.2803C15.36 10.421 15.5507 10.5 15.7496 10.5C15.9486 10.5 16.1393 10.421 16.28 10.2803C16.4206 10.1397 16.4996 9.94891 16.4996 9.75V7.5H19.6637L20.9921 18.75H2.99964Z" fill="currentColor"/>
          </svg>
          ADD TO CART
        </button>
      </div>
    </div>
  </dialog>
</div>

{% stylesheet %}
  /* ===== Arenus Collection Products Grid — Mobile-first ===== */

  .arenus-cpg {
    max-width: 1440px;
    margin: 0 auto;
  }

  /* ── Filter buttons ── */
  .arenus-cpg__filters {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 20px;
  }

  .arenus-cpg__filters-row {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  .arenus-cpg__filters-row--categories {
    overflow-x: auto;
    flex-wrap: nowrap;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .arenus-cpg__filters-row--categories::-webkit-scrollbar {
    display: none;
  }

  .arenus-cpg__filters-row--animals {
    flex-wrap: nowrap;
  }

  .arenus-cpg__filter-btn {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 4px;
    padding: 12px 20px;
    background-color: #f9f9f9;
    color: #000000;
    border: 1px solid transparent;
    border-radius: 6px;
    font-family: var(--font-body--family);
    font-weight: 500;
    font-size: 14px;
    line-height: 1;
    text-transform: uppercase;
    letter-spacing: 0;
    cursor: pointer;
    white-space: nowrap;
    transition: background-color 0.15s ease, border-color 0.15s ease;
  }

  .arenus-cpg__filter-btn:hover {
    /* background-color: #ffffff; */
    border-color: #000000;
  }

  .arenus-cpg__filter-btn:first-child {
    margin-left: 20px;
  }

  .arenus-cpg__filter-btn:last-child {
    margin-right: 20px;
  }

  .arenus-cpg__filter-btn.is-active {
    background-color: #ffffff;
    border-color: #000000;
  }

  .arenus-cpg__filters-row.is-loading {
    opacity: 0.5;
    pointer-events: none;
  }

  .arenus-cpg__filter-btn--animal {
    flex: 1;
  }

  .arenus-cpg__filter-btn--animal svg {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }

  /* ── Empty state ── */
  .arenus-cpg__empty {
    text-align: center;
    padding: 60px 20px;
  }

  .arenus-cpg__empty p {
    font-family: var(--font-body--family);
    font-weight: var(--font-body--weight);
    font-size: 16px;
    line-height: 1.6;
    color: #808085;
    margin: 0;
  }

  /* ── Products grid ── */
  .arenus-cpg__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px 16px;
    padding-inline: 20px;
  }

  /* ── Product card ── */
  .arenus-cpg__card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 12px;
    text-decoration: none;
    color: inherit;
    min-width: 0;
  }

  .arenus-cpg__card-link {
    position: absolute;
    inset: 0;
    z-index: 1;
    text-decoration: none;
  }

  /* Image area */
  .arenus-cpg__card-image {
    aspect-ratio: 1;
    background-color: var(--arenus-cpg-image-bg, #fffcea);
    border-radius: 12px;
    padding: 16px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .arenus-cpg__card-image img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  /* Info area */
  .arenus-cpg__card-info {
    display: flex;
    flex-direction: column;
    gap: 0;
    min-width: 0;
  }

  /* Star rating */
  .arenus-cpg__rating {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .arenus-cpg__stars {
    display: flex;
    align-items: center;
    gap: 0;
  }

  .arenus-cpg__stars svg {
    width: 12px;
    height: 12px;
    flex-shrink: 0;
  }

  .arenus-cpg__review-count {
    font-family: var(--font-body--family);
    font-weight: var(--font-body--weight);
    font-size: 12px;
    line-height: 1.4;
    letter-spacing: -0.12px;
    color: #808085;
  }

  /* Title + price */
  .arenus-cpg__title-price {
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 0;
    overflow: hidden;
  }

  .arenus-cpg__title {
    font-family: var(--font-body--family);
    font-weight: var(--font-body--weight);
    font-size: 16px;
    line-height: 1.6;
    letter-spacing: -0.32px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    min-width: 0;
  }

  .arenus-cpg__price {
    font-family: var(--font-body--family);
    font-weight: 700;
    font-size: 12px;
    line-height: 1.4;
    letter-spacing: -0.12px;
    white-space: nowrap;
  }

  /* Tag badges */
  .arenus-cpg__tags {
    display: none;
  }

  /* ===== Card Add-to-Cart Button (mobile: bottom of card) ===== */
  .arenus-cpg__add-btn {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 4px;
    width: 100%;
    padding: 12px 16px;
    background-color: #e6b236;
    color: #ffffff;
    border: none;
    border-radius: 6px;
    font-family: var(--font-body--family);
    font-weight: 500;
    font-size: 14px;
    line-height: 1;
    text-transform: uppercase;
    letter-spacing: 0;
    cursor: pointer;
    flex-shrink: 0;
  }

  .arenus-cpg__add-btn.is-sold-out {
    background-color: #d4d4d4;
    cursor: not-allowed;
  }

  .arenus-cpg__add-btn.is-loading {
    opacity: 0.6;
