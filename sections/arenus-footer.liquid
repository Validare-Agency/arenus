{%- comment -%}
  Arenus — Custom Footer
  Replaces the generic Horizon footer with a branded layout:
  Brand info | Nav menus | Newsletter | Bottom bar
{%- endcomment -%}

{%- liquid
  assign brand_block = nil
  assign nav_blocks = ''
  assign newsletter_block = nil

  for block in section.blocks
    case block.type
      when 'brand_info'
        assign brand_block = block
      when 'nav_menu'
        if nav_blocks == ''
          assign nav_blocks = block.id
        else
          assign nav_blocks = nav_blocks | append: ',' | append: block.id
        endif
      when 'newsletter'
        assign newsletter_block = block
    endcase
  endfor

  assign nav_block_ids = nav_blocks | split: ','
-%}

<footer
  id="ArenusFooter-{{ section.id }}"
  class="arenus-footer"
  style="
    --arenus-footer-bg: {{ section.settings.background_color }};
    --arenus-footer-btn-color: {{ section.settings.button_color }};
    padding-block-start: {{ section.settings.padding_top }}px;
    padding-block-end: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="arenus-footer__inner">
    {%- comment -%} ══════════ TOP ROW ══════════ {%- endcomment -%}
    <div class="arenus-footer__top">

      {%- comment -%} ── Brand info block ── {%- endcomment -%}
      {%- if brand_block -%}
        <div class="arenus-footer__brand" {{ brand_block.shopify_attributes }}>
          {%- comment -%} Logo {%- endcomment -%}
          {%- liquid
            assign footer_logo = brand_block.settings.logo
            if footer_logo == blank
              assign footer_logo = settings.logo
            endif
          -%}
          {%- if footer_logo != blank -%}
            <a href="{{ routes.root_url }}" class="arenus-footer__logo-link" aria-label="{{ shop.name }}">
              <img
                class="arenus-footer__logo"
                src="{{ footer_logo | image_url: width: 180 }}"
                alt="{{ shop.name }}"
                width="90"
                height="23"
                loading="lazy"
              >
            </a>
          {%- endif -%}

          {%- comment -%} Contact info {%- endcomment -%}
          <div class="arenus-footer__contact">
            {%- if brand_block.settings.address != blank -%}
              <p class="arenus-footer__address">{{ brand_block.settings.address }}</p>
            {%- endif -%}
            {%- if brand_block.settings.phone != blank -%}
              <p class="arenus-footer__phone">
                <a href="tel:{{ brand_block.settings.phone | remove: '(' | remove: ')' | remove: ' ' | remove: '-' }}">
                  {{ brand_block.settings.phone }}
                </a>
              </p>
            {%- endif -%}
          </div>

          {%- comment -%} Social icons {%- endcomment -%}
          <div class="arenus-footer__socials">
            {%- if brand_block.settings.instagram_url != blank -%}
              <a href="{{ brand_block.settings.instagram_url }}" class="arenus-footer__social-link" aria-label="Instagram" target="_blank" rel="noopener noreferrer">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M16.8045 8.2755C17.401 8.2755 17.8845 7.79197 17.8845 7.1955C17.8845 6.59903 17.401 6.1155 16.8045 6.1155C16.208 6.1155 15.7245 6.59903 15.7245 7.1955C15.7245 7.79197 16.208 8.2755 16.8045 8.2755Z" fill="black"/>
