{%- liquid
  assign has_image = false

  if section.settings.image != blank
    assign has_image = true
  endif

  assign fetch_priority = 'auto'
  if section.index == 1
    assign fetch_priority = 'high'
  endif
-%}

<div
  id="ArenusCollectionBanner-{{ section.id }}"
  class="arenus-cb"
  style="
    --arenus-cb-bg: {{ section.settings.background_color }};
    --arenus-cb-text: {{ section.settings.text_color }};
    --arenus-cb-media-opacity: {{ section.settings.media_opacity | divided_by: 100.0 }};
  "
>
  {%- comment -%} Background image {%- endcomment -%}
  <div class="arenus-cb__media">
    {%- if has_image -%}
      {{
        section.settings.image
        | image_url: width: 3840
        | image_tag:
          width: section.settings.image.width,
          widths: '416, 600, 800, 1200, 1600, 1920, 2560, 3840',
          height: section.settings.image.height,
          alt: section.settings.image.alt,
          class: 'arenus-cb__image',
          sizes: '100vw',
          fetchpriority: fetch_priority
      }}
    {%- endif -%}
  </div>

  {%- comment -%} Overlay {%- endcomment -%}
  {%- if section.settings.show_overlay -%}
    {% render 'overlay', settings: section.settings %}
  {%- endif -%}

  {%- comment -%} Content {%- endcomment -%}
  <div class="arenus-cb__content">
    {%- comment -%} Breadcrumb {%- endcomment -%}
    <nav class="arenus-cb__breadcrumb" aria-label="Breadcrumb">
      <a href="{{ routes.root_url }}" class="arenus-cb__breadcrumb-link">
        <span class="arenus-cb__breadcrumb-back-icon">
          {%- render 'icon-caret-left', width: 12, height: 12 -%}
        </span>
        <span>Home</span>
      </a>
      <span class="arenus-cb__breadcrumb-separator" aria-hidden="true">
        {%- render 'icon-caret-right', width: 12, height: 12 -%}
      </span>
      <span class="arenus-cb__breadcrumb-current" aria-current="page">{{ collection.title }}</span>
    </nav>

    {%- comment -%} Text group {%- endcomment -%}
    <div class="arenus-cb__text-group">
      {%- if section.settings.heading != blank -%}
        <h1 class="arenus-cb__heading">{{ section.settings.heading }}</h1>
      {%- endif -%}

      {%- if section.settings.description != blank -%}
        <div class="arenus-cb__body">{{ section.settings.description }}</div>
      {%- endif -%}
    </div>
  </div>
</div>

{% stylesheet %}
  /* ===== Arenus Collection Banner — Mobile-first ===== */

  .arenus-cb {
    position: relative;
    overflow: hidden;
    background-color: var(--arenus-cb-bg, #191919);
    color: var(--arenus-cb-text, #fff);
  }

  /* Background image */
  .arenus-cb__media {
    position: absolute;
    inset: 0;
    opacity: var(--arenus-cb-media-opacity, 0.5);
    z-index: 0;
  }

  .arenus-cb__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center center;
  }

  /* Content */
  .arenus-cb__content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    gap: 12px;
    padding: 20px;
    min-height: 400px;
  }

  /* ── Breadcrumb ── */
  .arenus-cb__breadcrumb {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .arenus-cb__breadcrumb-link {
    display: flex;
    align-items: center;
    gap: 8px;
    color: inherit;
    text-decoration: none;
    font-family: var(--font-body--family);
    font-size: 12px;
    line-height: 1.4;
    letter-spacing: -0.12px;
  }

  /* Mobile: show back icon, hide separator + current page */
  .arenus-cb__breadcrumb-back-icon {
    display: flex;
    align-items: center;
  }

  .arenus-cb__breadcrumb-separator,
  .arenus-cb__breadcrumb-current {
    display: none;
  }

  /* ── Text group ── */
  .arenus-cb__text-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .arenus-cb__heading {
    font-family: var(--font-heading--family);
    font-style: var(--font-heading--style);
    font-weight: var(--font-heading--weight);
    font-size: 40px;
    line-height: 1;
    letter-spacing: -0.8px;
    margin: 0;
  }

  .arenus-cb__body {
    font-family: var(--font-body--family);
    font-weight: var(--font-body--weight);
    font-size: 14px;
    line-height: 1.5;
    letter-spacing: -0.14px;
  }

  .arenus-cb__body p {
    margin: 0;
  }

  /* ===== Desktop ===== */
  @media screen and (min-width: 750px) {
    .arenus-cb__content {
      gap: 40px;
      padding: 40px;
      min-height: 460px;
    }

    .arenus-cb__heading {
      font-size: var(--font-h1--size);
    }

    /* Desktop: hide back icon, show separator + current page, underline Home */
    .arenus-cb__breadcrumb-back-icon {
      display: none;
    }

    .arenus-cb__breadcrumb-separator {
      display: flex;
      align-items: center;
    }

    .arenus-cb__breadcrumb-current {
      display: inline;
      font-family: var(--font-body--family);
      font-size: 12px;
      line-height: 1.4;
      letter-spacing: -0.12px;
    }

    .arenus-cb__breadcrumb-link {
      text-decoration: none;
    }

    .arenus-cb__breadcrumb-link:hover {
      text-decoration: underline;
    }

    .arenus-cb__text-group {
      max-width: 670px;
    }

    .arenus-cb__body {
      font-size: 16px;
      line-height: 1.6;
      letter-spacing: -0.32px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Arenus Collection Banner",
  "tag": "section",
  "class": "arenus-cb-wrapper section-wrapper",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our Collection for Animal Health Product"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Our dog and horse supplements are expertly formulated and research proven to give you the solutions and support you've been looking for.</p>"
    },
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "range",
      "id": "media_opacity",
      "label": "Image opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 50
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#191919"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Overlay"
    },
    {
      "type": "checkbox",
      "id": "show_overlay",
      "label": "Show overlay",
      "default": true
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay color",
      "alpha": true,
      "default": "#00000033",
      "visible_if": "{{ section.settings.show_overlay }}"
    },
    {
      "type": "select",
      "id": "overlay_style",
      "label": "Overlay style",
      "options": [
        {
          "value": "solid",
          "label": "Solid"
        },
        {
          "value": "gradient",
          "label": "Gradient"
        }
      ],
      "default": "gradient",
      "visible_if": "{{ section.settings.show_overlay }}"
    },
    {
      "type": "select",
      "id": "gradient_direction",
      "label": "Gradient direction",
      "options": [
        {
          "value": "to top",
          "label": "Up"
        },
        {
          "value": "to bottom",
          "label": "Down"
        }
      ],
      "default": "to bottom",
      "visible_if": "{{ section.settings.show_overlay and section.settings.overlay_style == 'gradient' }}"
    }
  ],
  "presets": [
    {
      "name": "Arenus Collection Banner",
      "category": "Banners",
      "settings": {
        "heading": "Our Collection for Animal Health Product",
        "media_opacity": 50,
        "background_color": "#191919",
        "text_color": "#ffffff",
        "show_overlay": true,
        "overlay_color": "#00000033",
        "overlay_style": "gradient",
        "gradient_direction": "to bottom"
      }
    }
  ]
}
{% endschema %}
