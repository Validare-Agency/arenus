{%- doc -%}
  Renders the top utility bar above the main header.
  Contains announcement text and a Shopify Markets country selector.

  @param {object} section - The section object with settings
{%- enddoc -%}

{% if section.settings.show_top_bar %}
  <div
    class="header-top-bar"
    style="
      --top-bar-bg: {{ section.settings.top_bar_bg_color }};
      --top-bar-text: {{ section.settings.top_bar_text_color }};
      --top-bar-border: {{ section.settings.top_bar_border_color }};
    "
  >
    <div class="header-top-bar__inner">
      <div class="header-top-bar__left">
        {% if section.settings.top_bar_announcement != blank %}
          <span class="header-top-bar__announcement">
            {{- section.settings.top_bar_announcement -}}
          </span>
        {% endif %}
      </div>

      <div class="header-top-bar__right">
        {% if section.settings.show_country_selector and localization.available_countries.size > 1 %}
          <div class="header-top-bar__country" data-country-selector>
            {%- form 'localization', id: 'TopBarCountryForm', class: 'header-top-bar__country-form' -%}
              <input type="hidden" name="return_to" value="{{ request.path }}">
              <button
                type="button"
                class="header-top-bar__country-toggle"
                aria-expanded="false"
                data-country-toggle
              >
                {{ localization.country | image_url: width: 24 | image_tag: class: 'header-top-bar__flag-img', loading: 'lazy' }}
                <span class="header-top-bar__country-label">{{ localization.country.iso_code }}</span>
                <span class="header-top-bar__caret svg-wrapper">
                  {{- 'icon-caret-down.svg' | inline_asset_content -}}
                </span>
              </button>

              <div class="header-top-bar__country-dropdown" data-country-dropdown hidden>
                {%- for country in localization.available_countries -%}
                  <button
                    type="submit"
                    name="country_code"
                    value="{{ country.iso_code }}"
                    class="header-top-bar__country-option{% if country.iso_code == localization.country.iso_code %} is-active{% endif %}"
                  >
                    {{ country | image_url: width: 24 | image_tag: class: 'header-top-bar__flag-img', loading: 'lazy' }}
                    <span>{{ country.iso_code }}</span>
                  </button>
                {%- endfor -%}
              </div>
            {%- endform -%}
          </div>
        {% endif %}
      </div>
    </div>
  </div>

  <script>
    (function() {
      var selector = document.querySelector('[data-country-selector]');
      if (!selector) return;

      var toggle = selector.querySelector('[data-country-toggle]');
      var dropdown = selector.querySelector('[data-country-dropdown]');
      if (!toggle || !dropdown) return;

      toggle.addEventListener('click', function(e) {
        e.stopPropagation();
        var expanded = toggle.getAttribute('aria-expanded') === 'true';
        toggle.setAttribute('aria-expanded', !expanded);
        dropdown.hidden = expanded;
      });

      /* Close on outside click */
      document.addEventListener('click', function(e) {
        if (!selector.contains(e.target)) {
          toggle.setAttribute('aria-expanded', 'false');
          dropdown.hidden = true;
        }
      });
    })();
  </script>
{% endif %}

{% stylesheet %}
  .header-top-bar {
    background-color: var(--top-bar-bg, #191919);
    border-bottom: 1px solid var(--top-bar-border, #45484a);
  }

  .header-top-bar__inner {
    max-width: var(--page-width);
    margin: 0 auto;
    padding: 8px 40px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 32px;
  }

  .header-top-bar__left {
    display: flex;
    align-items: center;
  }

  .header-top-bar__right {
    display: flex;
    align-items: center;
  }

  .header-top-bar__announcement {
    font-size: 14px;
    color: var(--top-bar-text, #FFF);
  }

  /* ── Country selector ── */
  .header-top-bar__country {
    position: relative;
    display: flex;
    align-items: center;
  }

  .header-top-bar__country-form {
    display: contents;
  }

  .header-top-bar__country-toggle {
    display: flex;
    align-items: center;
    gap: 4px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    color: #fff;
    font-size: 12px;
    line-height: 1.4;
    letter-spacing: -0.12px;
  }

  .header-top-bar__country-label {
    color: #fff;
  }

  .header-top-bar__caret {
    display: flex;
    align-items: center;
  }

  .header-top-bar__caret svg {
    width: 14px;
    height: 14px;
    color: #fff;
  }

  .header-top-bar__flag-img {
    width: 19px;
    height: 14px;
    border-radius: 2px;
    object-fit: cover;
    flex-shrink: 0;
  }

  .header-top-bar__country-dropdown {
    position: absolute;
    top: calc(100% + 8px);
    right: 0;
    background: #2a2a2a;
    border: 1px solid #45484a;
    border-radius: 6px;
    overflow: hidden;
    z-index: 100;
    min-width: 120px;
  }

  .header-top-bar__country-dropdown[hidden] {
    display: none;
  }

  .header-top-bar__country-option {
    display: flex;
    align-items: center;
    gap: 8px;
    width: 100%;
    padding: 8px 12px;
    background: none;
    border: none;
    color: #fff;
    font-size: 12px;
    cursor: pointer;
    transition: background-color 0.15s ease;
  }

  .header-top-bar__country-option:hover {
    background-color: #3a3a3a;
  }

  .header-top-bar__country-option.is-active {
    background-color: #333;
  }

  @media screen and (max-width: 749px) {
    .header-top-bar__inner {
      padding: 8px 20px;
    }

    .header-top-bar__announcement {
      font-size: 12px;
    }
  }
{% endstylesheet %}
