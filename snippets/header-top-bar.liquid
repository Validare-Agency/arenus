{%- doc -%}
  Renders the top utility bar above the main header.
  Contains configurable links and a country selector dropdown.

  @param {object} section - The section object with settings
{%- enddoc -%}

{% if section.settings.show_top_bar %}
  <div
    class="header-top-bar"
    style="
      --top-bar-bg: {{ section.settings.top_bar_bg_color }};
      --top-bar-text: {{ section.settings.top_bar_text_color }};
      --top-bar-border: {{ section.settings.top_bar_border_color }};
    "
  >
    <div class="header-top-bar__inner">
      <div class="header-top-bar__links">
        {% if section.settings.top_bar_link_1_text != blank %}
          <a
            href="{{ section.settings.top_bar_link_1_url | default: '/' }}"
            class="header-top-bar__link"
          >
            {{- section.settings.top_bar_link_1_text -}}
          </a>
        {% endif %}

        {% if section.settings.top_bar_link_2_text != blank %}
          <a
            href="{{ section.settings.top_bar_link_2_url | default: '/' }}"
            class="header-top-bar__link"
          >
            {{- section.settings.top_bar_link_2_text -}}
          </a>
        {% endif %}

        {% if section.settings.show_country_selector %}
          <div class="header-top-bar__country">
            <button
              type="button"
              class="header-top-bar__country-toggle"
              aria-expanded="false"
              aria-controls="country-selector-dropdown"
            >
              <span class="header-top-bar__flag header-top-bar__flag--us"></span>
              <span class="header-top-bar__country-label">US</span>
              <span class="header-top-bar__caret svg-wrapper">
                {{- 'icon-caret-down.svg' | inline_asset_content -}}
              </span>
            </button>
            <div
              id="country-selector-dropdown"
              class="header-top-bar__country-dropdown"
              hidden
            >
              <button
                type="button"
                class="header-top-bar__country-option"
                data-country="US"
                data-flag-class="header-top-bar__flag--us"
              >
                <span class="header-top-bar__flag header-top-bar__flag--us"></span>
                <span>US</span>
              </button>
              <button
                type="button"
                class="header-top-bar__country-option"
                data-country="CA"
                data-flag-class="header-top-bar__flag--ca"
              >
                <span class="header-top-bar__flag header-top-bar__flag--ca"></span>
                <span>Canada</span>
              </button>
            </div>
          </div>
        {% endif %}
      </div>
    </div>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', function () {
      const toggle = document.querySelector('.header-top-bar__country-toggle');
      const dropdown = document.querySelector('.header-top-bar__country-dropdown');
      if (!toggle || !dropdown) return;

      toggle.addEventListener('click', function (e) {
        e.stopPropagation();
        const expanded = toggle.getAttribute('aria-expanded') === 'true';
        toggle.setAttribute('aria-expanded', !expanded);
        dropdown.hidden = expanded;
      });

      dropdown.querySelectorAll('.header-top-bar__country-option').forEach(function (option) {
        option.addEventListener('click', function () {
          const country = option.dataset.country;
          const flagClass = option.dataset.flagClass;
          toggle.querySelector('.header-top-bar__country-label').textContent = country;
          const flagEl = toggle.querySelector('.header-top-bar__flag');
          flagEl.className = 'header-top-bar__flag ' + flagClass;
          toggle.setAttribute('aria-expanded', 'false');
          dropdown.hidden = true;
        });
      });

      document.addEventListener('click', function () {
        toggle.setAttribute('aria-expanded', 'false');
        dropdown.hidden = true;
      });
    });
  </script>
{% endif %}

{% stylesheet %}
  .header-top-bar {
    background-color: var(--top-bar-bg, #191919);
    border-bottom: 1px solid var(--top-bar-border, #45484a);
    padding: 8px 40px;
    display: flex;
    justify-content: flex-end;
  }

  .header-top-bar__inner {
    width: 100%;
    display: flex;
    justify-content: flex-end;
  }

  .header-top-bar__links {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .header-top-bar__link {
    font-size: 12px;
    line-height: 1.4;
    letter-spacing: -0.12px;
    color: var(--top-bar-text, #ddd);
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .header-top-bar__link:hover {
    opacity: 0.8;
  }

  .header-top-bar__country {
    position: relative;
    display: flex;
    align-items: center;
  }

  .header-top-bar__country-toggle {
    display: flex;
    align-items: center;
    gap: 4px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    color: #fff;
    font-size: 12px;
    line-height: 1.4;
    letter-spacing: -0.12px;
  }

  .header-top-bar__country-label {
    color: #fff;
  }

  .header-top-bar__caret {
    display: flex;
    align-items: center;
  }

  .header-top-bar__caret svg {
    width: 14px;
    height: 14px;
    color: #fff;
  }

  .header-top-bar__flag {
    width: 19px;
    height: 14px;
    border-radius: 4px;
    background-size: cover;
    background-position: center;
    display: inline-block;
    flex-shrink: 0;
  }

  .header-top-bar__flag--us {
    background-image: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 60 30"><clipPath id="a"><path d="M0 0v30h60V0z"/></clipPath><clipPath id="b"><path d="M0 0v15h30V0z"/></clipPath><g clip-path="url(%23a)"><path fill="%23b22234" d="M0 0h60v30H0z"/><path stroke="%23fff" stroke-width="2.31" d="M0 3.46h60M0 8.08h60M0 12.69h60M0 17.31h60M0 21.92h60M0 26.54h60"/></g><path fill="%23234" d="M0 0h24v16.15H0z" clip-path="url(%23b)"/><g fill="%23fff" transform="scale(.32)"><g id="d"><g id="c"><g id="e"><g id="f"><path id="g" d="M6 2l2 6H0l2-6 2 6z" transform="translate(1.5 2)"/><use href="%23g" x="12"/></g><use href="%23f" x="24"/></g><use href="%23e" x="48"/></g><use href="%23c" y="10"/><use href="%23c" y="20"/></g><use href="%23d" x="6" y="5"/></g></svg>');
  }

  .header-top-bar__flag--ca {
    background-image: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 60 30"><path fill="%23f00" d="M0 0h15v30H0zM45 0h15v30H45z"/><path fill="%23fff" d="M15 0h30v30H15z"/><path fill="%23f00" d="M30 5l-1.5 4.5-4-2 2 4.5H22l3 2.5-1 3.5 3-2.5v5h2v-5l3 2.5-1-3.5 3-2.5h-4.5l2-4.5-4 2z"/></svg>');
  }

  .header-top-bar__country-dropdown {
    position: absolute;
    top: calc(100% + 8px);
    right: 0;
    background: #2a2a2a;
    border: 1px solid #45484a;
    border-radius: 6px;
    overflow: hidden;
    z-index: 100;
    min-width: 120px;
  }

  .header-top-bar__country-option {
    display: flex;
    align-items: center;
    gap: 8px;
    width: 100%;
    padding: 8px 12px;
    background: none;
    border: none;
    color: #fff;
    font-size: 12px;
    cursor: pointer;
    transition: background-color 0.15s ease;
  }

  .header-top-bar__country-option:hover {
    background-color: #3a3a3a;
  }

  @media screen and (max-width: 749px) {
    .header-top-bar {
      padding: 8px 20px;
    }

    .header-top-bar__inner {
      justify-content: space-between;
    }

    .header-top-bar__links {
      flex: 1;
      justify-content: space-between;
    }
  }
{% endstylesheet %}
