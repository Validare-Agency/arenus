{%- doc -%}
  Arenus Subscription Selector
  Renders two cards (Subscribe and save / One-time Purchase) for products with Bold
  subscriptions configured. Hides entirely if the product has no selling plan groups
  or the current variant has no allocations.

  @param {object} product - Required. The product object.
  @param {string} [selector_id] - Optional. Unique suffix for DOM ids. Defaults to product.id.
{%- enddoc -%}

{%- liquid
  assign sp_group = product.selling_plan_groups | first
  assign has_plans = false
  if sp_group and sp_group.selling_plans.size > 0
    assign has_plans = true
  endif
  assign variant = product.selected_or_first_available_variant
  assign selector_id = selector_id | default: product.id
-%}

{%- if has_plans -%}
  {%- assign first_plan = sp_group.selling_plans | first -%}
  {%- assign first_allocation = null -%}
  {%- for alloc in variant.selling_plan_allocations -%}
    {%- if alloc.selling_plan_id == first_plan.id -%}
      {%- assign first_allocation = alloc -%}
      {%- break -%}
    {%- endif -%}
  {%- endfor -%}

  {%- comment -%} Compute discount percentage and discounted price from the selling plan's price adjustment
    (source of truth from Bold), falling back to allocation price {%- endcomment -%}
  {%- assign initial_discount_pct = 0 -%}
  {%- assign initial_discounted_price = variant.price -%}
  {%- assign first_adjustment = first_plan.price_adjustments | first -%}
  {%- if first_adjustment -%}
    {%- if first_adjustment.value_type == 'percentage' -%}
      {%- assign initial_discount_pct = first_adjustment.value | round -%}
      {%- assign multiplier = 100 | minus: first_adjustment.value -%}
      {%- assign initial_discounted_price = variant.price | times: multiplier | divided_by: 100 -%}
    {%- elsif first_adjustment.value_type == 'fixed_amount' -%}
      {%- assign initial_discounted_price = variant.price | minus: first_adjustment.value -%}
      {%- if variant.price > 0 -%}
        {%- assign initial_discount_pct = first_adjustment.value | times: 100 | divided_by: variant.price -%}
      {%- endif -%}
    {%- elsif first_adjustment.value_type == 'price' -%}
      {%- assign initial_discounted_price = first_adjustment.value -%}
      {%- if variant.price > 0 -%}
        {%- assign diff = variant.price | minus: first_adjustment.value -%}
        {%- assign initial_discount_pct = diff | times: 100 | divided_by: variant.price -%}
      {%- endif -%}
    {%- endif -%}
  {%- elsif first_allocation and variant.price > 0 -%}
    {%- assign initial_discounted_price = first_allocation.price -%}
    {%- assign diff = variant.price | minus: first_allocation.price -%}
    {%- assign initial_discount_pct = diff | times: 100 | divided_by: variant.price -%}
  {%- endif -%}

  <div
    class="arenus-sub-selector"
    data-sub-selector="{{ selector_id }}"
    data-sub-variant="{{ variant.id }}"
  >
    {%- comment -%} Hidden input submitted with the form / read by JS on add-to-cart {%- endcomment -%}
    <input type="hidden" name="selling_plan" value="{{ first_plan.id }}" data-sub-plan-input>

    {%- comment -%} ══════════ Subscribe & Save card ══════════ {%- endcomment -%}
    <label class="arenus-sub-selector__card arenus-sub-selector__card--subscribe arenus-sub-selector__card--selected" data-sub-card="subscribe">
      <input type="radio" name="purchase_type_{{ selector_id }}" value="subscribe" class="arenus-sub-selector__radio-input" data-sub-radio checked>
      <span class="arenus-sub-selector__radio-visual" aria-hidden="true">
        <span class="arenus-sub-selector__radio-dot"></span>
      </span>

      <div class="arenus-sub-selector__content">
        <div class="arenus-sub-selector__top">
          <div class="arenus-sub-selector__info">
            <span class="arenus-sub-selector__label">Subscribe and save</span>
            <div class="arenus-sub-selector__price-row">
              <span class="arenus-sub-selector__price-strike" data-sub-price-strike{% if initial_discount_pct == 0 %} style="display:none"{% endif %}>{{ variant.price | money }}</span>
              <span class="arenus-sub-selector__price-discount" data-sub-price-discount>{{ initial_discounted_price | money }}</span>
            </div>
          </div>
          <span class="arenus-sub-selector__badge" data-sub-badge{% if initial_discount_pct == 0 %} style="display:none"{% endif %}>Save {{ initial_discount_pct }}%</span>
        </div>

        <div class="arenus-sub-selector__cadence-wrap" data-sub-cadence-wrap>
          <select class="arenus-sub-selector__cadence" data-sub-cadence aria-label="Delivery frequency">
            {%- for plan in sp_group.selling_plans -%}
              <option value="{{ plan.id }}"{% if plan.id == first_plan.id %} selected{% endif %}>{{ plan.name }}</option>
            {%- endfor -%}
          </select>
          <span class="arenus-sub-selector__cadence-caret" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M5 7.5L10 12.5L15 7.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </span>
        </div>
      </div>
    </label>

    {%- comment -%} ══════════ One-time Purchase card ══════════ {%- endcomment -%}
    <label class="arenus-sub-selector__card arenus-sub-selector__card--onetime" data-sub-card="onetime">
      <input type="radio" name="purchase_type_{{ selector_id }}" value="onetime" class="arenus-sub-selector__radio-input" data-sub-radio>
      <span class="arenus-sub-selector__radio-visual" aria-hidden="true">
        <span class="arenus-sub-selector__radio-dot"></span>
      </span>

      <div class="arenus-sub-selector__content">
        <div class="arenus-sub-selector__info">
          <span class="arenus-sub-selector__label">One-time Purchase</span>
          <span class="arenus-sub-selector__price-onetime" data-sub-price-onetime>{{ variant.price | money }}</span>
        </div>
      </div>
    </label>

    {%- comment -%} JSON blob consumed by inline JS (and by external code for modals) {%- endcomment -%}
    <script type="application/json" data-sub-data>
      {
        "selectorId": {{ selector_id | json }},
        "groupId": {{ sp_group.id | json }},
        "plans": [
          {%- for plan in sp_group.selling_plans -%}
            {%- assign adj = plan.price_adjustments | first -%}
            {
              "id": {{ plan.id }},
              "name": {{ plan.name | json }},
              "adjustment": {% if adj %}{ "value_type": {{ adj.value_type | json }}, "value": {{ adj.value }} }{% else %}null{% endif %}
            }{% unless forloop.last %},{% endunless %}
          {%- endfor -%}
        ],
        "variants": {
          {%- for v in product.variants -%}
            "{{ v.id }}": {
              "price": {{ v.price }},
              "allocations": {
                {%- for alloc in v.selling_plan_allocations -%}
                  "{{ alloc.selling_plan_id }}": { "price": {{ alloc.price }} }{% unless forloop.last %},{% endunless %}
                {%- endfor -%}
              }
            }{% unless forloop.last %},{% endunless %}
          {%- endfor -%}
        }
      }
    </script>
  </div>
{%- endif -%}

<script>
  (function() {
    var container = document.querySelector('[data-sub-selector="{{ selector_id }}"]');
    if (!container) return;

    var dataEl = container.querySelector('[data-sub-data]');
    if (!dataEl) return;

    var data;
    try {
      data = JSON.parse(dataEl.textContent);
    } catch (err) {
      console.error('Arenus subscription: failed to parse data', err);
      return;
    }

    var planInput = container.querySelector('[data-sub-plan-input]');
    var cadenceSelect = container.querySelector('[data-sub-cadence]');
    var priceStrikeEl = container.querySelector('[data-sub-price-strike]');
    var priceDiscountEl = container.querySelector('[data-sub-price-discount]');
    var priceOnetimeEl = container.querySelector('[data-sub-price-onetime]');
    var badgeEl = container.querySelector('[data-sub-badge]');
    var subscribeCard = container.querySelector('[data-sub-card="subscribe"]');
    var onetimeCard = container.querySelector('[data-sub-card="onetime"]');
    var radios = container.querySelectorAll('[data-sub-radio]');

    var state = {
      variantId: String(container.getAttribute('data-sub-variant')),
      planId: cadenceSelect ? cadenceSelect.value : (data.plans[0] && String(data.plans[0].id)),
      mode: 'subscribe' /* or 'onetime' */
    };

    function formatMoney(cents) {
      var n = Number(cents || 0);
      if (window.Shopify && Shopify.formatMoney) {
        try { return Shopify.formatMoney(n, '${{amount}}'); } catch (e) {}
      }
      return '$' + (n / 100).toFixed(2);
    }

    function getVariantData(variantId) {
      return data.variants && data.variants[String(variantId)];
    }

    function getAllocation(variantData, planId) {
      if (!variantData || !variantData.allocations) return null;
      return variantData.allocations[String(planId)] || null;
    }

    function findPlan(planId) {
      for (var i = 0; i < data.plans.length; i++) {
        if (String(data.plans[i].id) === String(planId)) return data.plans[i];
      }
      return null;
    }

    function computeDiscountPct(variantPrice, allocationPrice, plan) {
      /* Prefer the selling plan's price adjustment (source of truth from Bold) */
      if (plan && plan.adjustment && plan.adjustment.value_type === 'percentage') {
        return Math.round(plan.adjustment.value);
      }
      if (!variantPrice || variantPrice <= 0) return 0;
      var diff = variantPrice - allocationPrice;
      if (diff <= 0) return 0;
      return Math.round((diff * 100) / variantPrice);
    }

    function computeDiscountedPrice(variantPrice, alloc, plan) {
      /* Apply the selling plan's adjustment directly to get the accurate discounted price */
      if (plan && plan.adjustment) {
        var a = plan.adjustment;
        if (a.value_type === 'percentage') {
          return Math.round(variantPrice * (1 - a.value / 100));
        }
        if (a.value_type === 'fixed_amount') {
          return Math.max(0, variantPrice - a.value);
        }
        if (a.value_type === 'price') {
          return a.value;
        }
      }
      /* Fall back to allocation price if present */
      if (alloc) return alloc.price;
      return variantPrice;
    }

    function updatePrices() {
      var v = getVariantData(state.variantId);
      if (!v) return;

      /* Always update one-time price */
      if (priceOnetimeEl) priceOnetimeEl.textContent = formatMoney(v.price);

      /* Strikethrough always shows variant price */
      if (priceStrikeEl) priceStrikeEl.textContent = formatMoney(v.price);

      var alloc = getAllocation(v, state.planId);
      var plan = findPlan(state.planId);
      var pct = computeDiscountPct(v.price, alloc ? alloc.price : v.price, plan);
      var discountedPrice = computeDiscountedPrice(v.price, alloc, plan);

      if (priceDiscountEl) priceDiscountEl.textContent = formatMoney(discountedPrice);

      if (pct > 0) {
        if (priceStrikeEl) priceStrikeEl.style.display = '';
        if (badgeEl) {
          badgeEl.textContent = 'Save ' + pct + '%';
          badgeEl.style.display = '';
        }
      } else {
        if (priceStrikeEl) priceStrikeEl.style.display = 'none';
        if (badgeEl) badgeEl.style.display = 'none';
      }
    }

    function updateSelection() {
      if (state.mode === 'subscribe') {
        subscribeCard.classList.add('arenus-sub-selector__card--selected');
        onetimeCard.classList.remove('arenus-sub-selector__card--selected');
        if (planInput) planInput.value = state.planId;
      } else {
        onetimeCard.classList.add('arenus-sub-selector__card--selected');
        subscribeCard.classList.remove('arenus-sub-selector__card--selected');
        if (planInput) planInput.value = '';
      }

      /* Hide the PDP's normal price element when subscribe is active; restore otherwise.
         We target the element by class so this doesn't need explicit binding. */
      var pdpPrice = document.querySelector('.arenus-product__price-block');
      if (pdpPrice) {
        pdpPrice.style.display = state.mode === 'subscribe' ? 'none' : '';
      }
      var pdpComparePrice = document.querySelector('.arenus-product__price-compare');
      if (pdpComparePrice) {
        pdpComparePrice.style.display = state.mode === 'subscribe' ? 'none' : '';
      }
    }

    /* ── Radio click handlers ── */
    radios.forEach(function(r) {
      r.addEventListener('change', function() {
        state.mode = r.value;
        updateSelection();
      });
    });

    /* Also handle clicks on the card itself (not just the radio) */
    [subscribeCard, onetimeCard].forEach(function(card) {
      if (!card) return;
      card.addEventListener('click', function(e) {
        /* Let the native label click flow through to the radio; nothing extra to do here */
      });
    });

    /* ── Cadence change ── */
    if (cadenceSelect) {
      cadenceSelect.addEventListener('change', function() {
        state.planId = cadenceSelect.value;
        if (state.mode === 'subscribe' && planInput) planInput.value = state.planId;
        updatePrices();
      });
    }

    /* ── Public API for external code (variant change from parent section) ── */
    window.arenusSub = window.arenusSub || {};
    window.arenusSub['{{ selector_id }}'] = {
      setVariant: function(variantId) {
        var vStr = String(variantId);
        if (!data.variants[vStr]) {
          /* Variant has no allocations — hide the selector entirely */
          container.style.display = 'none';
          state.variantId = vStr;
          return;
        }
        container.style.display = '';
        state.variantId = vStr;
        container.setAttribute('data-sub-variant', vStr);
        updatePrices();
      },
      getSellingPlanId: function() {
        return state.mode === 'subscribe' ? state.planId : null;
      },
      getMode: function() {
        return state.mode;
      }
    };

    /* Initial render */
    updateSelection();
    updatePrices();
  })();
</script>
